{% extends 'base.html.twig' %}
{% block title %}🔐 Configuration 2FA{% endblock %}
{% block body %}
<div class="form-panel" style="max-width:460px; margin:60px auto; text-align:center;">
    <div class="form-panel-header">
        <span class="form-panel-icon">🔑</span>
        <div>
            <div class="form-panel-title">Configuration en deux étapes</div>
            <div class="form-panel-sub">Scannez le QR code avec votre application d'authentification</div>
        </div>
    </div>
    <hr class="panel-divider">

    {# ── QR Code ── #}
    <div style="margin: 24px auto;">
        <img src="{{ qrDataUri }}" alt="QR Code 2FA"
             style="width:200px; height:200px; border:4px solid #f0f0f0; border-radius:12px;">
    </div>

    {# ── Manual key fallback ── #}
    <p style="font-size:13px; color:var(--text-muted); margin-bottom:6px;">
        Vous ne pouvez pas scanner ? Entrez cette clé manuellement :
    </p>
    <div style="background:#f5f5f5; border-radius:8px; padding:10px 16px;
                font-family:monospace; font-size:15px; letter-spacing:3px;
                word-break:break-all; margin-bottom:24px;">
        {{ manualKey }}
    </div>

    {# ── Instructions ── #}
    <ol style="text-align:left; font-size:14px; line-height:2; padding-left:20px; margin-bottom:24px;">
        <li>Installez <strong>Google Authenticator</strong> ou <strong>Authy</strong> sur votre téléphone</li>
        <li>Ouvrez l'app et appuyez sur <strong>"+"</strong></li>
        <li>Scannez le QR code ci-dessus</li>
        <li>Entrez le code à 6 chiffres sur la page suivante</li>
    </ol>

    <a href="{{ path('app_2fa_check') }}" class="btn btn-primary" style="width:100%;">
        ➡️ J'ai scanné, continuer
    </a>

    <div style="margin-top:16px;">
        <a href="{{ path('app_logout') }}" style="color:var(--text-muted); font-size:13px;">
            🚪 Se déconnecter
        </a>
    </div>
</div>
{% endblock %}
{% extends 'base.html.twig' %}
{% block title %}🔐 Vérification 2FA{% endblock %}
{% block body %}
<div class="form-panel" style="max-width:420px; margin:60px auto; text-align:center;">
    <div class="form-panel-header">
        <span class="form-panel-icon">📱</span>
        <div>
            <div class="form-panel-title">Vérification en deux étapes</div>
            <div class="form-panel-sub">Entrez le code de votre application d'authentification</div>
        </div>
    </div>
    <hr class="panel-divider">

    {% for message in app.flashes('error') %}
        <div class="flash flash-error">{{ message }}</div>
    {% endfor %}

    <form method="post">
        <div class="form-group" style="margin:24px 0 16px;">
            <input type="text" name="auth_code" class="form-control"
                   inputmode="numeric" pattern="[0-9]*" maxlength="6"
                   required autofocus placeholder="000000"
                   style="font-size:28px; letter-spacing:8px; text-align:center; font-weight:800;">
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;">
            ✅ Valider
        </button>
    </form>

    <div style="margin-top:16px;">
        <a href="{{ path('app_logout') }}" style="color:var(--text-muted); font-size:13px;">
            🚪 Se déconnecter
        </a>
    </div>
</div>
{% endblock %}
{% extends 'base.html.twig' %}
{% block body %}
<div style="display:flex; justify-content:center; padding:60px 16px;">
<div style="background:white; border-radius:20px; box-shadow:0 8px 40px rgba(0,0,0,0.10); padding:40px; width:100%; max-width:400px;">

    <div style="text-align:center; margin-bottom:24px;">
        <div style="font-size:40px;">🔑</div>
        <div style="font-size:22px; font-weight:800;">Nouveau mot de passe</div>
    </div>

    {% for message in app.flashes('error') %}
        <div class="flash flash-error">❌ {{ message }}</div>
    {% endfor %}

    <form method="post">
        <div class="form-group" style="margin-bottom:14px;">
            <label class="form-label">Nouveau mot de passe</label>
            <input type="password" name="password" id="password" class="form-control" required minlength="8">
            <span style="font-size:11px; color:#6B7280;">8 caractères, une majuscule, un chiffre</span>
        </div>
        <div class="form-group" style="margin-bottom:20px;">
            <label class="form-label">Confirmer</label>
            <input type="password" name="confirmPassword" id="confirm" class="form-control" required>
            <span class="field-error" id="err-confirm"></span>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center;">
            Enregistrer
        </button>
    </form>
</div>
</div>

<script>
document.querySelector('form').addEventListener('submit', function(e) {
    const pass    = document.getElementById('password').value;
    const confirm = document.getElementById('confirm').value;
    const err     = document.getElementById('err-confirm');

    if (pass !== confirm) {
        err.textContent = 'Les mots de passe ne correspondent pas.';
        e.preventDefault();
    } else {
        err.textContent = '';
    }
});
</script>
{% endblock %}
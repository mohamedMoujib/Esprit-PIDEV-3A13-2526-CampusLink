{% extends 'base.html.twig' %}
{% block body %}
<div style="display:flex; justify-content:center; padding:60px 16px;">
<div style="background:white; border-radius:20px; box-shadow:0 8px 40px rgba(0,0,0,0.10); padding:40px; width:100%; max-width:400px;">

    <div style="text-align:center; margin-bottom:24px;">
        <div style="font-size:40px;">📬</div>
        <div style="font-size:22px; font-weight:800;">Vérifier le code</div>
        <div style="font-size:13px; color:#6B7280; margin-top:4px;">Entrez le code à 6 chiffres envoyé par email</div>
    </div>

    {% for message in app.flashes('error') %}
        <div class="flash flash-error">❌ {{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('success') %}
        <div class="flash flash-success">✅ {{ message }}</div>
    {% endfor %}

    <form method="post">
        <div class="form-group" style="margin-bottom:16px;">
            <label class="form-label">Code de vérification</label>
            <input type="text" name="code" class="form-control"
                   placeholder="000000" maxlength="6"
                   style="font-size:28px; letter-spacing:8px; text-align:center; font-weight:800;"
                   required>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center;">
            Vérifier
        </button>
    </form>

    <p style="text-align:center; font-size:13px; color:#6B7280; margin-top:16px;">
        Pas reçu ? <a href="{{ path('app_forgot_password') }}" style="color:#5D5FEF;">Renvoyer</a>
    </p>
</div>
</div>
{% endblock %}
{% extends 'base.html.twig' %}
{% block body %}
<div style="display:flex; justify-content:center; padding:60px 16px;">
<div style="background:white; border-radius:20px; box-shadow:0 8px 40px rgba(0,0,0,0.10); padding:40px; width:100%; max-width:400px;">

    <div style="text-align:center; margin-bottom:24px;">
        <div style="font-size:40px;">🔐</div>
        <div style="font-size:22px; font-weight:800;">Mot de passe oublié</div>
        <div style="font-size:13px; color:#6B7280; margin-top:4px;">Entrez votre email pour recevoir un code</div>
    </div>

    {% for message in app.flashes('error') %}
        <div class="flash flash-error">❌ {{ message }}</div>
    {% endfor %}

    <form method="post">
        <div class="form-group" style="margin-bottom:16px;">
            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-control" placeholder="votre@email.com" required>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center;">
            Envoyer le code
        </button>
    </form>

    <p style="text-align:center; font-size:13px; color:#6B7280; margin-top:16px;">
        <a href="{{ path('app_login') }}" style="color:#5D5FEF;">← Retour à la connexion</a>
    </p>
</div>
</div>
{% endblock %}
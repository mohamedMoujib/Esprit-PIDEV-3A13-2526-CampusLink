{% extends 'base.html.twig' %}

{% block title %}Mes avis - CampusLink{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/StudentReviewsManagement.css') }}">
{% endblock %}

{% block body %}

<div class="page-content">

    <!-- FLASH MESSAGES -->
    {% for msg in app.flashes('success') %}
        <div class="flash flash-success">✅ {{ msg }}</div>
    {% endfor %}
    {% for msg in app.flashes('error') %}
        <div class="flash flash-error">❌ {{ msg }}</div>
    {% endfor %}

    <!-- HEADER -->
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:25px;">
        <h1 class="page-title">Mes avis</h1>
        {% if confirmedReservations is not empty %}
            <button onclick="document.getElementById('addForm').style.display='block'" class="btn btn-primary">
                ✍️ Laisser un avis
            </button>
        {% else %}
            <span class="no-reservation-hint">💡 Aucune réservation confirmée sans avis pour le moment</span>
        {% endif %}
    </div>

    <!-- FORMULAIRE AJOUT -->
    <div class="form-card" id="addForm" style="display:none;">
        <h2>Laisser un avis</h2>
        {{ form_start(form, {'action': path('student_reviews_add'), 'attr': {'id': 'addReviewForm'}}) }}

            <div class="form-group">
                <label>Réservation concernée <span class="required">*</span></label>
                <select name="reservation_id" id="reservationSelect" class="comment-area" style="min-height:auto; padding:10px;" required>
                    <option value="">-- Choisir une réservation --</option>
                    {% for res in confirmedReservations %}
                        <option value="{{ res.reservation_id }}" data-prestataire="{{ res.prestataire_id }}">
                            {{ res.service_title }} — {{ res.prestataire_name }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <input type="hidden" name="prestataire_id" id="prestataireInput" value="">

            <div class="form-group">
                <label>Votre note <span class="required">*</span></label>
                {{ form_widget(form.rating) }}
                {{ form_errors(form.rating) }}
            </div>

            <div class="form-group" style="position: relative;">
                <label>
                    Votre commentaire <span class="required">*</span>
                    <span class="char-counter" id="addCounter">0 / {{ maxCommentLength }}</span>
                </label>
                <div class="textarea-wrapper">
                    {{ form_widget(form.comment, {'attr': {'id': 'review_form_comment', 'class': 'comment-area', 'autocomplete': 'off'}}) }}
                    <div id="ai-suggestion-overlay" class="ai-suggestion-overlay"></div>
                </div>
                {{ form_errors(form.comment) }}
                <small class="hint">💡 L'IA vous suggère du texte en temps réel. Appuyez sur <kbd>Tab</kbd> ou <kbd>→</kbd> pour accepter.</small>
            </div>

            <div style="display:flex; gap:10px;">
                <button type="submit" class="btn btn-primary" id="addSubmitBtn">Publier</button>
                <button type="button" onclick="document.getElementById('addForm').style.display='none'" class="btn btn-secondary">Annuler</button>
            </div>
        {{ form_end(form) }}
    </div>

    <!-- LISTE DES AVIS -->
    <div class="reviews-list">
        {% if reviews is empty %}
            <div class="empty-state">
                ⭐ Aucun avis pour le moment.<br>
                <small>Vos avis apparaîtront ici après vos réservations confirmées.</small>
            </div>
        {% else %}
            {% for review in reviews %}
                {% set rating = review.rating %}
                {% set absRating = (rating < 0 ? -rating : rating) %}
                {% if absRating > 5 %}
                    {% set absRating = 5 %}
                {% endif %}
                {% set colorClass = rating < 0 ? 'stars-negative' : (rating > 0 ? 'stars-positive' : 'stars-neutral') %}

                <div class="review-card">
                    <div class="card-header">
                        <div class="card-info">
                            <div class="service-title">
                                📚 {{ review.reservation.service.title ?? 'Service inconnu' }}
                            </div>
                            <div class="student-name">
                                avec {{ review.prestataire.name ?? 'Prestataire inconnu' }}
                            </div>
                        </div>
                        <div class="card-date">{{ 'now'|date('d/m/Y') }}</div>
                    </div>

                    <div class="stars-display">
                        <span class="stars {{ colorClass }}">
                            {% for i in 1..5 %}{% if i <= absRating %}★{% else %}☆{% endif %}{% endfor %}
                        </span>
                        <span class="stars-badge {{ colorClass }}">
                            {{ rating > 0 ? '(+' ~ rating ~ ')' : '(' ~ rating ~ ')' }}
                        </span>
                    </div>

                    <p class="review-comment">{{ review.comment }}</p>

                    {% if review.isReported %}
                        <div class="reported-badge">⚠️ Cet avis a été signalé</div>
                    {% endif %}

                    <div class="card-footer">
                        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                            <button onclick="openEditForm({{ review.id }}, {{ review.rating }}, '{{ review.comment|e('js') }}')" class="btn btn-secondary">✏️ Modifier</button>
                            <form method="post" action="{{ path('student_reviews_delete', {id: review.id}) }}" style="display:inline;" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet avis ? Cette action est irréversible.')">
                                <button type="submit" class="btn btn-danger">🗑 Supprimer</button>
                            </form>
                        </div>
                        
                        <!-- BOUTONS DE PARTAGE -->
                        <div class="share-buttons">
                            <button onclick="shareOnFacebook({{ review.id }}, '{{ review.reservation.service.title|e('js') }}', '{{ review.prestataire.name|e('js') }}', {{ review.rating }})" 
                                    class="btn-share btn-facebook" title="Partager sur Facebook">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                                </svg>
                            </button>
                            <button onclick="shareOnLinkedIn({{ review.id }}, '{{ review.reservation.service.title|e('js') }}', '{{ review.prestataire.name|e('js') }}', {{ review.rating }})" 
                                    class="btn-share btn-linkedin" title="Partager sur LinkedIn">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>
            {% endfor %}
        {% endif %}
    </div>

    <!-- PAGINATION -->
    <div style="display:flex; justify-content:center; align-items:center; gap:8px; margin-top:24px; flex-wrap:wrap;">
        {% if totalPages > 1 %}
            <a href="{{ path('student_reviews_index', {'page': currentPage - 1}) }}"
               class="btn btn-secondary"
               style="padding:6px 14px; font-size:13px; {{ currentPage == 1 ? 'pointer-events:none; opacity:0.4;' : '' }}">
                ‹ Préc
            </a>

            {% for i in 1..totalPages %}
                {% if i == 1 or i == totalPages or (i >= currentPage - 2 and i <= currentPage + 2) %}
                    <a href="{{ path('student_reviews_index', {'page': i}) }}"
                       style="padding:6px 12px; border-radius:6px; border:1px solid #d1d5db; font-size:13px; text-decoration:none;
                              background:{{ i == currentPage ? '#6c63ff' : '#fff' }};
                              color:{{ i == currentPage ? '#fff' : '#374151' }};">
                        {{ i }}
                    </a>
                {% elseif i == currentPage - 3 or i == currentPage + 3 %}
                    <span style="padding:6px 4px; color:#6b7280;">…</span>
                {% endif %}
            {% endfor %}

            <a href="{{ path('student_reviews_index', {'page': currentPage + 1}) }}"
               class="btn btn-secondary"
               style="padding:6px 14px; font-size:13px; {{ currentPage == totalPages ? 'pointer-events:none; opacity:0.4;' : '' }}">
                Suiv ›
            </a>

            <span style="font-size:12px; color:#6b7280; margin-left:8px;">Page {{ currentPage }} / {{ totalPages }}</span>
        {% endif %}
    </div>

</div>

<!-- MODAL ÉDITION -->
<div id="editModal" class="modal-overlay">
    <div class="form-card modal-box">
        <h2>Modifier l'avis</h2>
        <form method="post" id="editForm">
            <input type="hidden" name="rating" id="editRatingInput" value="0">

            <div class="form-group">
                <label>Votre note <span class="required">*</span></label>
                <div class="star-rating" id="editStarRating">
                    {% for i in 1..5 %}
                        <button type="button" class="star-btn" data-value="{{ -(6-i) }}">★</button>
                    {% endfor %}
                    <span class="separator">|</span>
                    {% for i in 1..5 %}
                        <button type="button" class="star-btn" data-value="{{ i }}">★</button>
                    {% endfor %}
                </div>
                <small class="hint">⬅️ Étoiles négatives &nbsp;|&nbsp; Étoiles positives ➡️</small>
            </div>

            <div class="form-group" style="position: relative;">
                <label>
                    Commentaire <span class="required">*</span>
                    <span class="char-counter" id="editCounter">0 / {{ maxCommentLength }}</span>
                </label>
                <textarea
                    name="comment"
                    id="editComment"
                    class="comment-area"
                    maxlength="{{ maxCommentLength }}"
                    autocomplete="off"
                    required
                ></textarea>
                <div id="ai-suggestion-overlay-edit" class="ai-suggestion-overlay"></div>
                <small class="hint">💡 L'IA vous suggère du texte en temps réel. Appuyez sur <kbd>Tab</kbd> ou <kbd>→</kbd> pour accepter.</small>
            </div>

            <div style="display:flex; gap:10px;">
                <button type="submit" class="btn btn-primary">Mettre à jour</button>
                <button type="button" onclick="document.getElementById('editModal').classList.remove('open')" class="btn btn-secondary">Annuler</button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL PRÉVISUALISATION PARTAGE -->
<div id="sharePreviewModal" class="modal-overlay">
    <div class="form-card modal-box" style="max-width: 500px;">
        <h2 style="display: flex; align-items: center; gap: 10px;">
            <span style="font-size: 28px;">📤</span>
            Partager votre avis
        </h2>
        
        <div style="background: #f9fafb; padding: 20px; border-radius: 8px; margin: 20px 0;">
            <div style="font-size: 13px; color: #6b7280; margin-bottom: 8px; font-weight: 600;">Message qui sera partagé :</div>
            <div id="sharePreviewMessage" style="font-size: 15px; color: #111827; line-height: 1.6; white-space: pre-wrap;"></div>
        </div>

        <div style="display:flex; gap:10px; justify-content: flex-end;">
            <button type="button" id="shareCancelBtn" class="btn btn-secondary">Annuler</button>
            <button type="button" id="shareConfirmBtn" class="btn btn-primary">Partager</button>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
const MAX_LENGTH = {{ maxCommentLength }};
const MIN_LENGTH = {{ minCommentLength }};

// ===================== AI-POWERED AUTOCOMPLETE (GROQ) =====================
class AISuggestionEngine {
    constructor(textareaId, overlayId, ratingInputId, serviceSelectId = null) {
        this.textarea = document.getElementById(textareaId);
        this.overlay = document.getElementById(overlayId);
        this.ratingInput = document.getElementById(ratingInputId);
        this.serviceSelect = serviceSelectId ? document.getElementById(serviceSelectId) : null;
        
        if (!this.textarea || !this.overlay) {
            console.warn('AI Suggestion: textarea ou overlay introuvable', {textareaId, overlayId});
            return;
        }
        
        if (!this.ratingInput) {
            console.warn('AI Suggestion: rating input introuvable, recherche alternative...', ratingInputId);
            // Chercher l'input rating généré par le bundle
            this.ratingInput = document.querySelector('input[name="review_form[rating]"]') || 
                              document.querySelector('input[id*="rating"]');
            console.log('Rating input trouvé:', this.ratingInput);
        }
        
        this.currentSuggestion = '';
        this.isLoading = false;
        this.debounceTimer = null;
        
        console.log('AI Suggestion Engine initialisé', {
            textarea: !!this.textarea,
            overlay: !!this.overlay,
            ratingInput: !!this.ratingInput,
            serviceSelect: !!this.serviceSelect
        });
        
        this.init();
    }
    
    init() {
        // Événement input avec debounce
        this.textarea.addEventListener('input', () => {
            this.updateOverlayPosition();
            this.debouncedFetchSuggestion();
        });
        
        // Événement scroll pour ajuster la position
        this.textarea.addEventListener('scroll', () => {
            this.updateOverlayPosition();
        });
        
        // Accepter la suggestion avec Tab ou flèche droite
        this.textarea.addEventListener('keydown', (e) => {
            if ((e.key === 'Tab' || e.key === 'ArrowRight') && this.currentSuggestion) {
                e.preventDefault();
                this.acceptSuggestion();
            } else if (e.key === 'Escape') {
                this.clearSuggestion();
            }
        });
        
        // Mettre à jour quand la note change
        if (this.ratingInput) {
            // Écouter les événements change et input
            this.ratingInput.addEventListener('change', () => {
                console.log('Rating change event:', this.ratingInput.value);
                this.debouncedFetchSuggestion();
            });
            
            this.ratingInput.addEventListener('input', () => {
                console.log('Rating input event:', this.ratingInput.value);
                this.debouncedFetchSuggestion();
            });
        }
    }
    
    debouncedFetchSuggestion() {
        clearTimeout(this.debounceTimer);
        this.debounceTimer = setTimeout(() => {
            this.fetchSuggestion();
        }, 1500); // 1.5 secondes pour laisser le temps à l'utilisateur
    }
    
    async fetchSuggestion() {
        const text = this.textarea.value;
        const rating = this.ratingInput ? parseInt(this.ratingInput.value) || 0 : 0;
        
        console.log('Fetch suggestion:', {text: text.substring(0, 50), rating, textLength: text.length});
        
        // Ne pas suggérer si le texte est trop long ou si pas de note
        if (text.length > 200 || text.length < 3 || rating === 0) {
            console.log('Conditions non remplies pour suggestion');
            this.clearSuggestion();
            return;
        }
        
        // Récupérer le nom du service si disponible
        let serviceName = '';
        if (this.serviceSelect) {
            const selectedOption = this.serviceSelect.options[this.serviceSelect.selectedIndex];
            serviceName = selectedOption ? selectedOption.text : '';
        }
        
        this.isLoading = true;
        console.log('Appel API suggestion...', {text, rating, serviceName});
        
        try {
            const response = await fetch('/student/reviews/api/suggest-comment', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    text: text,
                    rating: rating,
                    service: serviceName
                })
            });
            
            if (!response.ok) {
                console.error('Erreur API:', response.status, response.statusText);
                this.clearSuggestion();
                return;
            }
            
            const data = await response.json();
            console.log('Réponse API:', data);
            
            if (data.suggestion && data.suggestion.trim()) {
                this.showSuggestion(data.suggestion.trim());
            } else {
                this.clearSuggestion();
            }
        } catch (error) {
            console.error('Erreur lors de la récupération de la suggestion:', error);
            this.clearSuggestion();
        } finally {
            this.isLoading = false;
        }
    }
    
    showSuggestion(suggestion) {
        this.currentSuggestion = suggestion;
        const currentText = this.textarea.value;
        
        // Afficher la suggestion après le texte actuel
        this.overlay.textContent = currentText + suggestion;
        this.overlay.style.display = 'block';
        this.updateOverlayPosition();
        console.log('Suggestion affichée:', suggestion.substring(0, 50));
    }
    
    clearSuggestion() {
        this.currentSuggestion = '';
        this.overlay.textContent = '';
        this.overlay.style.display = 'none';
    }
    
    acceptSuggestion() {
        if (this.currentSuggestion) {
            this.textarea.value += this.currentSuggestion;
            this.clearSuggestion();
            
            // Déclencher l'événement input pour mettre à jour le compteur
            this.textarea.dispatchEvent(new Event('input'));
            this.textarea.focus();
            console.log('Suggestion acceptée');
        }
    }
    
    updateOverlayPosition() {
        // Synchroniser le scroll
        this.overlay.scrollTop = this.textarea.scrollTop;
        this.overlay.scrollLeft = this.textarea.scrollLeft;
    }
}

// Attendre que le DOM soit chargé
document.addEventListener('DOMContentLoaded', function() {
    console.log('Initialisation des moteurs de suggestion...');
    
    // Initialiser les moteurs de suggestion
    const addSuggestionEngine = new AISuggestionEngine(
        'review_form_comment',
        'ai-suggestion-overlay',
        'review_form_rating',
        'reservationSelect'
    );

    const editSuggestionEngine = new AISuggestionEngine(
        'editComment',
        'ai-suggestion-overlay-edit',
        'editRatingInput'
    );
});

// ===================== SELECT RÉSERVATION =====================
document.getElementById('reservationSelect')?.addEventListener('change', function () {
    const selected = this.options[this.selectedIndex];
    const prestataireId = selected.dataset.prestataire || '';
    document.getElementById('prestataireInput').value = prestataireId;
    console.log('Prestataire ID sélectionné:', prestataireId);
});

// ===================== COMPTEUR CARACTÈRES =====================
function initCounter(textareaId, counterId) {
    const textarea = document.getElementById(textareaId);
    const counter  = document.getElementById(counterId);
    if (!textarea || !counter) return;

    // Initialiser le compteur
    const updateCounter = () => {
        const len = textarea.value.length;
        counter.textContent = len + ' / ' + MAX_LENGTH;
        counter.style.color = len > MAX_LENGTH * 0.9 ? '#e74c3c' : (len < MIN_LENGTH ? '#f0a500' : '#27ae60');
    };

    textarea.addEventListener('input', updateCounter);
    updateCounter(); // Initialiser au chargement
}

initCounter('review_form_comment', 'addCounter');
initCounter('editComment', 'editCounter');

// ===================== STAR RATING =====================
function initStars(containerId, inputId) {
    const container = document.getElementById(containerId);
    const input     = document.getElementById(inputId);
    if (!container || !input) return;

    const stars = container.querySelectorAll('.star-btn');
    stars.forEach(star => {
        star.addEventListener('mouseenter', () => highlight(stars, parseInt(star.dataset.value)));
        star.addEventListener('mouseleave', () => highlight(stars, parseInt(input.value)));
        star.addEventListener('click', () => {
            input.value = star.dataset.value;
            highlight(stars, parseInt(star.dataset.value));
        });
    });
}

function highlight(stars, val) {
    stars.forEach(s => {
        const v = parseInt(s.dataset.value);
        s.classList.remove('active-positive', 'active-negative');
        if (val < 0 && v >= val && v < 0) s.classList.add('active-negative');
        if (val > 0 && v <= val && v > 0) s.classList.add('active-positive');
    });
}

initStars('starRating',     'ratingInput');
initStars('editStarRating', 'editRatingInput');

// ===================== EDIT MODAL =====================
function openEditForm(id, rating, comment) {
    document.getElementById('editForm').action = '/student/reviews/edit/' + id;
    document.getElementById('editComment').value = comment;
    document.getElementById('editRatingInput').value = rating;

    const counter = document.getElementById('editCounter');
    if (counter) {
        counter.textContent = comment.length + ' / ' + MAX_LENGTH;
        counter.style.color = comment.length < MIN_LENGTH ? '#f0a500' : '#27ae60';
    }

    const stars = document.querySelectorAll('#editStarRating .star-btn');
    highlight(stars, rating);
    document.getElementById('editModal').classList.add('open');
}

document.getElementById('editModal').addEventListener('click', function (e) {
    if (e.target === this) this.classList.remove('open');
});

// ===================== SOCIAL SHARING =====================
function getStarsEmoji(rating) {
    const absRating = Math.abs(rating);
    return '⭐'.repeat(Math.min(absRating, 5));
}

function generateShareMessage(serviceTitle, prestataireNom, rating) {
    const absRating = Math.abs(rating);
    const stars = getStarsEmoji(rating);
    return `J'ai laissé un avis de ${absRating}/5 ${stars} sur un cours de "${serviceTitle}" avec ${prestataireNom} sur CampusLink!`;
}

function showSharePreview(message, shareFunction) {
    const modal = document.getElementById('sharePreviewModal');
    const messageEl = document.getElementById('sharePreviewMessage');
    const confirmBtn = document.getElementById('shareConfirmBtn');
    
    messageEl.textContent = message;
    modal.classList.add('open');
    
    // Remplacer l'événement du bouton
    const newBtn = confirmBtn.cloneNode(true);
    confirmBtn.parentNode.replaceChild(newBtn, confirmBtn);
    
    newBtn.addEventListener('click', () => {
        modal.classList.remove('open');
        shareFunction();
    });
}

function shareOnFacebook(reviewId, serviceTitle, prestataireNom, rating) {
    const message = generateShareMessage(serviceTitle, prestataireNom, rating);
    const url = window.location.origin + '/student/reviews';
    
    showSharePreview(message, () => {
        const shareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}&quote=${encodeURIComponent(message)}`;
        window.open(shareUrl, '_blank', 'width=600,height=400');
    });
}

function shareOnTwitter(reviewId, serviceTitle, prestataireNom, rating) {
    const message = generateShareMessage(serviceTitle, prestataireNom, rating) + ' #CampusLink #Avis';
    const url = window.location.origin + '/student/reviews';
    
    showSharePreview(message, () => {
        const shareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(message)}&url=${encodeURIComponent(url)}`;
        window.open(shareUrl, '_blank', 'width=600,height=400');
    });
}

function shareOnLinkedIn(reviewId, serviceTitle, prestataireNom, rating) {
    const message = generateShareMessage(serviceTitle, prestataireNom, rating);
    const url = window.location.origin + '/student/reviews';
    
    showSharePreview(message, () => {
        const shareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`;
        window.open(shareUrl, '_blank', 'width=600,height=400');
    });
}

// Fermer la modal de prévisualisation
document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('sharePreviewModal');
    if (modal) {
        modal.addEventListener('click', (e) => {
            if (e.target === modal) {
                modal.classList.remove('open');
            }
        });
        
        const cancelBtn = document.getElementById('shareCancelBtn');
        if (cancelBtn) {
            cancelBtn.addEventListener('click', () => {
                modal.classList.remove('open');
            });
        }
    }
});
</script>

<style>
@keyframes slideIn {
    from { transform: translateX(400px); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
}

@keyframes slideOut {
    from { transform: translateX(0); opacity: 1; }
    to { transform: translateX(400px); opacity: 0; }
}
</style>

{% endblock %}
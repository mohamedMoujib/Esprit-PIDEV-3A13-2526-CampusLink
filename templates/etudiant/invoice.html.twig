{% extends 'base.html.twig' %}

{% block title %}Mes Factures{% endblock %}

{% block body %}
<div class="container mt-4" style="max-width: 1100px;">
    <h2 class="mb-4" style="font-weight: 600; font-size: 28px;">Mes Factures</h2>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <!-- Date Filter Only -->
    <form method="get" class="d-flex gap-2 align-items-center mb-4">
        <input
            type="date"
            name="date"
            class="form-control form-control-lg"
            style="max-width: 220px;"
            value="{{ app.request.query.get('date') }}"
        >
        <button type="submit" class="btn btn-primary btn-lg px-5" style="background-color: #5b54e8; border-color: #5b54e8;">Filtrer</button>
    </form>

    <div class="table-responsive" style="border: 2px solid #5b54e8; border-radius: 12px; overflow: hidden;">
        <table class="table table-hover align-middle mb-0 text-center" style="font-size: 16px;">
            <thead style="background-color: #ededfd; border-bottom: 2px solid #5b54e8;">
                <tr>
                    <th class="fw-600 py-3" style="width: 60px; color: #5b54e8;">#</th>
                    <th class="fw-600 py-3" style="width: 180px; color: #5b54e8;">Date</th>
                    <th class="fw-600 py-3" style="color: #5b54e8;">Détails</th>
                    <th class="fw-600 py-3" style="width: 200px; color: #5b54e8;">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for invoice in invoices %}
                    <tr style="border-bottom: 1px solid #dddcfc;">
                        <td class="text-muted fw-semibold py-3">{{ loop.index }}</td>
                        <td class="text-nowrap py-3" style="font-size: 15px;">{{ invoice.issueDate ? invoice.issueDate|date('d/m/Y H:i') : 'N/A' }}</td>
                        <td class="py-3" style="font-size: 15px; line-height: 1.6; max-width: 420px; word-wrap: break-word;">
                            {{ invoice.details ?: 'Aucun détail' }}
                        </td>
                        <td class="py-3">
                            <div class="d-flex gap-3 justify-content-center">
                                <a href="{{ path('invoice_preview', {'id': invoice.id}) }}" class="btn btn-outline-primary btn-sm px-3" style="border-color: #5b54e8; color: #5b54e8; font-size: 14px;">Aperçu</a>
                                <form method="post" action="{{ path('invoice_delete', {'id': invoice.id}) }}" onsubmit="return confirm('Supprimer cette facture ?');">
                                    <button class="btn btn-sm px-3" style="background-color: #e24b4a; border-color: #e24b4a; color: white; font-size: 14px;">Supprimer</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center text-muted py-5" style="font-size: 16px;">Aucune facture trouvée pour cette date.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
{% extends 'base.html.twig' %}

{% block title %}Mes Factures{% endblock %}

{% block body %}

<style>
.custom-table th,
.custom-table td {
    border: 1px solid #dddcfc; /* lines between rows & columns */
    padding: 14px;
}

.custom-table thead th {
    color: #5b54e8;
    font-weight: 600;
    border-bottom: 2px solid #5b54e8;
}

.custom-table tbody tr:hover {
    background-color: #f7f7ff;
}
</style>

<div class="container mt-4" style="max-width: 1100px;">
    <h2 class="mb-4" style="font-weight: 600; font-size: 28px;">Mes Factures</h2>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <!-- Date Filter -->
    <form method="get" class="d-flex gap-2 align-items-center mb-4">
        <input
            type="date"
            name="date"
            class="form-control form-control-lg"
            style="max-width: 220px;"
            value="{{ app.request.query.get('date') }}"
        >
        <button type="submit" class="btn btn-primary btn-lg px-5"
                style="background-color: #5b54e8; border-color: #5b54e8;">
            Filtrer
        </button>
    </form>

    <!-- TABLE -->
<div class="table-responsive" style="border: 2px solid #5b54e8; border-radius: 12px; overflow-x: auto; margin: 0;">
    <table class="table align-middle mb-0 text-center custom-table w-100" style="font-size: 16px; table-layout: fixed;">
        
        <thead style="background-color: #ededfd;">
            <tr>
                <th style="width: 60px;">#</th>
                <th style="width: 180px;">Date</th>
                <th>Détails</th>
                <th style="width: 200px;">Actions</th>
            </tr>
        </thead>

        <tbody>
            {% for invoice in invoices %}
                <tr>
                    <td class="text-muted fw-semibold">{{ loop.index }}</td>

                    <td class="text-nowrap" style="font-size: 15px;">
                        {{ invoice.issueDate ? invoice.issueDate|date('d/m/Y H:i') : 'N/A' }}
                    </td>

                    <td style="font-size: 15px; line-height: 1.6; word-wrap: break-word;">
                        {{ invoice.details ?: 'Aucun détail' }}
                    </td>

                    <td>
                        <div class="d-flex gap-3 justify-content-center">
                            
                            <a href="{{ path('invoice_preview', {'id': invoice.id}) }}"
                               class="btn btn-outline-primary btn-sm px-3"
                               style="border-color: #5b54e8; color: #5b54e8;">
                                Aperçu
                            </a>

                            <form method="post"
                                  action="{{ path('invoice_delete', {'id': invoice.id}) }}"
                                  onsubmit="return confirm('Supprimer cette facture ?');">
                                <button class="btn btn-sm px-3"
                                        style="background-color: #e24b4a; border-color: #e24b4a; color: white;">
                                    Supprimer
                                </button>
                            </form>

                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center text-muted" style="font-size: 16px; padding: 14px;">
                        Aucune facture trouvée pour cette date.
                    </td>
                </tr>
            {% endfor %}
        </tbody>

    </table>
</div>
</div>

{% endblock %}
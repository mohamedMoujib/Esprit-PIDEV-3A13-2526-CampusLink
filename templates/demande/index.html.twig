{% extends 'base.html.twig' %}
{% block title %}Réservations — CampusLink{% endblock %}
{% block body %}

<div class="page-header">
    <div>
        <div class="page-title">Réservations</div>
        <div class="page-sub">
            {% if app.user.userType == 'PRESTATAIRE' %}Demandes reçues pour vos services{% else %}Vos demandes{% endif %}
        </div>
    </div>
</div>

{% if demandes|length == 0 %}
<div class="empty-state" style="text-align:center;">
    <div style="font-size:48px;margin-bottom:12px;">📋</div>
    <div>Aucune réservation pour le moment.</div>
</div>
{% else %}
<div style="display:flex;flex-direction:column;gap:14px;">
    {% for d in demandes %}
    <div class="card" style="padding:18px;display:flex;flex-direction:column;gap:10px;">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-wrap:wrap;">
            <div>
                <div style="font-weight:800;font-size:16px;">{{ d.service.title }}</div>
                <div style="font-size:13px;color:#6b7280;margin-top:4px;">
                    {% if app.user.userType == 'PRESTATAIRE' %}
                        Étudiant : {{ d.student.name }}
                    {% else %}
                        Prestataire : {{ d.prestataire.name }}
                    {% endif %}
                </div>
            </div>
            <span class="badge {% if d.status == 'PENDING' %}badge-pending{% elseif d.status == 'ACCEPTED' %}badge-active{% elseif d.status == 'REJECTED' %}badge-rejected{% else %}badge-inactive{% endif %}">
                {{ d.status }}
            </span>
        </div>
        {% if d.message %}
        <div style="font-size:14px;color:#374151;">{{ d.message }}</div>
        {% endif %}
        <div style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;">
            {% if app.user.userType == 'PRESTATAIRE' and d.status == 'PENDING' %}
            <form method="post" action="{{ path('demande_status', { id: d.id }) }}" class="inline-form" style="display:inline-flex;gap:8px;">
                <input type="hidden" name="_token" value="{{ csrf_token('demande_status_' ~ d.id) }}">
                <button type="submit" name="status" value="ACCEPTED" class="btn btn-primary btn-sm">Accepter</button>
                <button type="submit" name="status" value="REJECTED" class="btn btn-danger-outline btn-sm">Refuser</button>
            </form>
            {% endif %}
            {% if d.status == 'PENDING' and app.user == d.student %}
            <form method="post" action="{{ path('demande_delete', { id: d.id }) }}" onsubmit="return confirm('Annuler cette demande ?');" style="display:inline;">
                <input type="hidden" name="_token" value="{{ csrf_token('demande_delete_' ~ d.id) }}">
                <button type="submit" class="btn btn-ghost btn-sm">Annuler</button>
            </form>
            {% endif %}
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}

{% endblock %}

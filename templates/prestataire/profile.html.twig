{% extends "prestataire/layout.html.twig" %}

{% block prestataire_title %}Mon profil{% endblock %}
{% block prestataire_page_title %}Mon profil{% endblock %}
{% block prestataire_page_subtitle %}Gérez vos informations personnelles{% endblock %}

{% block prestataire_content %}
<div style="max-width: 900px;">
    <!-- Profile Header Card -->
    <div class="form-panel" style="padding: 30px; background: linear-gradient(135deg, var(--primary) 0%, #7c8fff 100%); color: white; border: none; margin-bottom: 30px;">
        <div style="display: flex; align-items: center; gap: 30px;">
            <div style="width: 120px; height: 120px; border-radius: 50%; background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; font-size: 48px; flex-shrink: 0;">
                {% if user.profilePicture %}
                    <img src="/uploads/profiles/{{ user.profilePicture }}" alt="{{ user.name }}" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;">
                {% else %}
                    {{ user.name|first|upper }}
                {% endif %}
            </div>
            <div>
                <div style="font-size: 28px; font-weight: 700; margin-bottom: 8px;">{{ user.name }}</div>
                <div style="font-size: 15px; opacity: 0.9; margin-bottom: 12px;">{{ user.email }}</div>
                <div style="display: inline-block; padding: 6px 12px; background: rgba(255,255,255,0.2); border-radius: 6px; font-size: 13px; font-weight: 600;">💼 Prestataire</div>
            </div>
        </div>
    </div>

    <!-- Personal Information -->
    <div class="form-panel" style="margin-bottom: 24px;">
        <div style="font-weight: 700; font-size: 16px; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 2px solid var(--border);">📋 Informations personnelles</div>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
            <div>
                <div style="font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; margin-bottom: 8px;">Nom</div>
                <div style="font-weight: 600; color: var(--text);">{{ user.name }}</div>
            </div>
            <div>
                <div style="font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; margin-bottom: 8px;">Email</div>
                <div style="font-weight: 600; color: var(--text);">{{ user.email }}</div>
            </div>
            <div>
                <div style="font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; margin-bottom: 8px;">Téléphone</div>
                <div style="font-weight: 600; color: var(--text);">{{ user.phone ?? 'Non fourni' }}</div>
            </div>
            <div>
                <div style="font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; margin-bottom: 8px;">Adresse</div>
                <div style="font-weight: 600; color: var(--text);">{{ user.address ?? 'Non fournie' }}</div>
            </div>
            <div>
                <div style="font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; margin-bottom: 8px;">Membre depuis</div>
                <div style="font-weight: 600; color: var(--text);">{{ user.createdAt|date('d/m/Y') }}</div>
            </div>
            <div>
                <div style="font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; margin-bottom: 8px;">Statut</div>
                <span class="badge {% if user.status == 'ACTIVE' %}badge-active{% elseif user.status == 'INACTIVE' %}badge-pending{% else %}badge-rejected{% endif %}">
                    {% if user.status == 'ACTIVE' %}✅ Actif
                    {% elseif user.status == 'INACTIVE' %}⏳ Inactif
                    {% else %}❌ Suspendu{% endif %}
                </span>
            </div>
        </div>
    </div>

    <!-- Additional Information -->
    <div class="form-panel" style="margin-bottom: 24px;">
        <div style="font-weight: 700; font-size: 16px; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 2px solid var(--border);">ℹ️ Informations supplémentaires</div>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
            <div>
                <div style="font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; margin-bottom: 8px;">Genre</div>
                <div style="font-weight: 600; color: var(--text);">
                    {% if user.gender == 'M' %}Masculin
                    {% elseif user.gender == 'F' %}Féminin
                    {% else %}Non spécifié{% endif %}
                </div>
            </div>
            <div>
                <div style="font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; margin-bottom: 8px;">Date de naissance</div>
                <div style="font-weight: 600; color: var(--text);">
                    {% if user.dateNaissance %}{{ user.dateNaissance|date('d/m/Y') }}{% else %}Non fournie{% endif %}
                </div>
            </div>
            <div>
                <div style="font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; margin-bottom: 8px;">Points de confiance</div>
                <div style="font-weight: 600; color: var(--text);">
                    {% if user.trustPoints %}⭐ {{ user.trustPoints }} points{% else %}Aucun point{% endif %}
                </div>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div style="display: flex; gap: 12px;">
        <a href="{{ path('app_logout') }}" class="btn btn-danger-outline">
            🚪 Déconnexion
        </a>
    </div>
</div>
{% endblock %}
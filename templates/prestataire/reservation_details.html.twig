{% extends "prestataire/layout.html.twig" %}

{% block prestataire_title %}Détails de la réservation{% endblock %}
{% block prestataire_page_title %}{{ reservation.service.title }}{% endblock %}
{% block prestataire_page_subtitle %}Réservation de {{ reservation.user.name }}{% endblock %}

{% block prestataire_content %}
<div style="max-width: 900px;">
    <!-- Status Badge -->
    <div style="margin-bottom: 20px;">
        <span class="badge {% if reservation.status == 'PENDING' %}badge-pending{% elseif reservation.status == 'CONFIRMED' %}badge-active{% else %}badge-rejected{% endif %}">
            {% if reservation.status == 'PENDING' %}⏳ En attente
            {% elseif reservation.status == 'CONFIRMED' %}✅ Confirmée
            {% else %}❌ Annulée{% endif %}
        </span>
    </div>

    <!-- Details Grid -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 30px;">
        <!-- Reservation Info -->
        <div class="form-panel">
            <div style="font-weight: 700; font-size: 16px; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 2px solid var(--border);">📅 Informations de réservation</div>
            
            <div style="margin-bottom: 16px;">
                <div style="font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; margin-bottom: 6px;">Date & Heure</div>
                <div style="font-weight: 600; color: var(--text);">{{ reservation.date|date('d/m/Y H:i') }}</div>
            </div>
            
            <div style="margin-bottom: 16px;">
                <div style="font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; margin-bottom: 6px;">Lieu</div>
                <div style="font-weight: 600; color: var(--text);">{{ reservation.localisation ?? 'Non spécifié' }}</div>
            </div>
            
            <div style="margin-bottom: 16px;">
                <div style="font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; margin-bottom: 6px;">Prix</div>
                <div style="font-weight: 700; color: var(--primary); font-size: 18px;">{{ reservation.price|number_format(2, '.', ',') }} DT</div>
            </div>
            
            <div>
                <div style="font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; margin-bottom: 6px;">Statut</div>
                <div style="font-weight: 600; color: var(--text);">
                    {% if reservation.status == 'PENDING' %}En attente
                    {% elseif reservation.status == 'CONFIRMED' %}Confirmée
                    {% else %}Annulée{% endif %}
                </div>
            </div>
        </div>

        <!-- Student Info -->
        <div class="form-panel">
            <div style="font-weight: 700; font-size: 16px; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 2px solid var(--border);">👤 Informations étudiant</div>
            
            <div style="margin-bottom: 16px;">
                <div style="font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; margin-bottom: 6px;">Nom</div>
                <div style="font-weight: 600; color: var(--text);">{{ reservation.user.name }}</div>
            </div>
            
            <div style="margin-bottom: 16px;">
                <div style="font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; margin-bottom: 6px;">Email</div>
                <div style="font-weight: 600; color: var(--primary);">{{ reservation.user.email }}</div>
            </div>
            
            <div style="margin-bottom: 16px;">
                <div style="font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; margin-bottom: 6px;">Téléphone</div>
                <div style="font-weight: 600; color: var(--text);">{{ reservation.user.phone ?? 'Non fourni' }}</div>
            </div>
            
            {% if reservation.user.universite %}
            <div>
                <div style="font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; margin-bottom: 6px;">Université</div>
                <div style="font-weight: 600; color: var(--text);">{{ reservation.user.universite }}</div>
            </div>
            {% endif %}
        </div>
    </div>

    <!-- Service Details -->
    <div class="form-panel" style="margin-bottom: 30px;">
        <div style="font-weight: 700; font-size: 16px; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 2px solid var(--border);">🛠️ Détails du service</div>
        
        <div style="margin-bottom: 16px;">
            <div style="font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; margin-bottom: 6px;">Service</div>
            <div style="font-weight: 600; color: var(--text);">{{ reservation.service.title }}</div>
        </div>
        
        <div style="margin-bottom: 16px;">
            <div style="font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; margin-bottom: 6px;">Description</div>
            <div style="color: var(--text); line-height: 1.5;">{{ reservation.service.description ?? 'Pas de description' }}</div>
        </div>
        
        {% if reservation.service.category %}
        <div>
            <div style="font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; margin-bottom: 6px;">Catégorie</div>
            <div style="font-weight: 600; color: var(--text);">{{ reservation.service.category.name }}</div>
        </div>
        {% endif %}
    </div>

    <!-- Actions -->
    {% if reservation.status == 'PENDING' %}
    <div style="display: flex; gap: 12px; margin-bottom: 24px;">
        <form method="POST" action="{{ path('prestataire_reservation_confirm', {'id': reservation.id}) }}" style="flex: 1;">
            <button type="submit" class="btn btn-primary" style="width: 100%;">
                ✅ Confirmer la réservation
            </button>
        </form>
        <form method="POST" action="{{ path('prestataire_reservation_cancel', {'id': reservation.id}) }}" style="flex: 1;">
            <button type="submit" class="btn btn-danger-outline" style="width: 100%;" onclick="return confirm('Êtes-vous sûr de vouloir annuler cette réservation ?');">
                ❌ Annuler la réservation
            </button>
        </form>
    </div>
    {% endif %}

    <!-- Back Link -->
    <a href="{{ path('prestataire_reservations') }}" class="btn btn-outline">
        ← Retour aux réservations
    </a>
</div>
{% endblock %}

{% extends 'base.html.twig' %}
{% block title %}Mon Profil — Admin CampusLink{% endblock %}

{% block body %}
<div style="max-width:900px; margin:0 auto;">

    {# ── Page title ── #}
    <div class="page-header">
        <div>
            <div class="page-title">👤 Mon Profil Admin</div>
            <div class="page-sub">Gérez vos informations personnelles</div>
        </div>
    </div>

    {# ── Flash messages ── #}
    {% for message in app.flashes('success') %}
        <div class="flash flash-success">✅ {{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="flash flash-error">❌ {{ message }}</div>
    {% endfor %}

    {# ══════════════════════════════════════
       CARD 1 — Avatar + Personal Info
    ══════════════════════════════════════ #}
    <div class="form-panel" style="margin-bottom:24px;">

        {# ── Avatar row ── #}
        <div style="display:flex; align-items:center; gap:24px;
                    padding-bottom:24px; border-bottom:1px solid var(--border);">

            {# Avatar display #}
            <div style="position:relative; width:100px; height:100px; flex-shrink:0;">
                {% if admin.profilePicture and 'res.cloudinary.com' in admin.profilePicture %}
                    {% set avatarSrc = admin.profilePicture|replace({
                        '/upload/': '/upload/w_200,h_200,c_fill,g_face,r_max,q_auto,f_auto/'
                    }) %}
                    <img id="avatarPreview"
                         src="{{ avatarSrc }}"
                         style="width:100px; height:100px; border-radius:50%;
                                object-fit:cover; border:3px solid var(--primary-light);"
                         onerror="this.style.display='none';
                                  document.getElementById('avatarDefault').style.display='flex';">
                    <div id="avatarDefault"
                         style="width:100px; height:100px; border-radius:50%; background:#e0e7ff;
                                display:none; align-items:center; justify-content:center; font-size:48px;">
                        👨‍💼
                    </div>
                {% else %}
                    <div id="avatarDefault"
                         style="width:100px; height:100px; border-radius:50%; background:#e0e7ff;
                                display:flex; align-items:center; justify-content:center; font-size:48px;">
                        👨‍💼
                    </div>
                    <img id="avatarPreview" src="" style="display:none;
                         width:100px; height:100px; border-radius:50%;
                         object-fit:cover; border:3px solid var(--primary-light);">
                {% endif %}
            </div>

            {# Info + upload/remove buttons #}
            <div>
                <div style="font-size:20px; font-weight:800; color:var(--text);">
                    {{ admin.name }}
                </div>
                <div style="font-size:13px; color:var(--text-muted); margin-top:2px;">
                    {{ admin.email }}
                </div>
                <div style="font-size:12px; color:var(--text-muted); margin-top:4px;">
                    Membre depuis {{ admin.createdAt ? admin.createdAt|date('d/m/Y') : 'N/A' }}
                </div>
                <span class="badge"
                      style="margin-top:8px; background:#fee2e2; color:#dc2626;
                             border:1px solid #fca5a5;">
                    👑 Administrateur
                </span>

                {# ── Upload form ── #}
                <form method="post"
                      action="{{ path('admin_profile') }}"
                      enctype="multipart/form-data"
                      data-turbo="false"
                      style="margin-top:12px; display:inline-flex; align-items:center; gap:8px;">
                    <input type="hidden" name="action" value="upload_photo">

                    <input type="file"
                           name="profile_picture"
                           id="photoInput"
                           accept="image/jpeg,image/png,image/gif,image/webp"
                           style="display:none;"
                           onchange="previewAndSubmit(this)">

                    <button type="button"
                            onclick="document.getElementById('photoInput').click()"
                            class="btn btn-ghost btn-sm">
                        📷 Changer la photo
                    </button>

                    {% if admin.profilePicture %}
                        <button type="submit"
                                formaction="{{ path('admin_profile') }}"
                                name="action"
                                value="remove_photo"
                                class="btn btn-sm btn-danger-outline"
                                onclick="return confirm('Supprimer la photo de profil ?')">
                            🗑 Supprimer
                        </button>
                    {% endif %}
                </form>

                <div style="font-size:11px; color:var(--text-muted); margin-top:6px;">
                    📷 JPG, PNG, GIF, WEBP — max 5MB
                </div>
            </div>

        </div>

        {# ── Personal Info Form ── #}
        <div class="form-panel-header">
            <span class="form-panel-icon">📋</span>
            <div>
                <div class="form-panel-title">Informations personnelles</div>
                <div class="form-panel-sub">Modifiez vos données de profil</div>
            </div>
        </div>
        <hr class="panel-divider">

        <form method="post" action="{{ path('admin_profile') }}"
              data-turbo="false" novalidate>
            <input type="hidden" name="action" value="save_profile">

            <div class="form-row" style="margin-bottom:16px;">
                <div class="form-group">
                    <label class="form-label">
                        Nom complet <span class="required-star">*</span>
                    </label>
                    <input type="text"
                           name="name"
                           class="form-control"
                           value="{{ admin.name }}"
                           required
                           minlength="2"
                           maxlength="100"
                           placeholder="Votre nom complet">
                </div>
                <div class="form-group">
                    <label class="form-label">
                        Email <span class="required-star">*</span>
                    </label>
                    <input type="email"
                           name="email"
                           class="form-control"
                           value="{{ admin.email }}"
                           required
                           placeholder="votre@email.com">
                </div>
            </div>

            <div class="form-row" style="margin-bottom:16px;">
                <div class="form-group">
                    <label class="form-label">Téléphone</label>
                    <input type="tel"
                           name="phone"
                           class="form-control"
                           value="{{ admin.phone ?? '' }}"
                           placeholder="ex: +21612345678">
                </div>
                <div class="form-group">
                    <label class="form-label">Adresse</label>
                    <input type="text"
                           name="address"
                           class="form-control"
                           value="{{ admin.address ?? '' }}"
                           placeholder="Votre adresse">
                </div>
            </div>

            <div class="form-row" style="margin-bottom:24px;">
                <div class="form-group">
                    <label class="form-label">Genre</label>
                    <select name="gender" class="form-control">
                        <option value="">Sélectionnez...</option>
                        <option value="male"
                            {% if admin.gender == 'male' %}selected{% endif %}>
                            Homme
                        </option>
                        <option value="female"
                            {% if admin.gender == 'female' %}selected{% endif %}>
                            Femme
                        </option>
                        <option value="other"
                            {% if admin.gender == 'other' %}selected{% endif %}>
                            Autre
                        </option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Compte créé le</label>
                    <input type="text"
                           class="form-control"
                           value="{{ admin.createdAt ? admin.createdAt|date('d/m/Y') : 'N/A' }}"
                           disabled
                           style="background:#f9fafb; color:var(--text-muted);">
                </div>
            </div>

            <div class="form-actions">
                <span style="font-size:13px; color:var(--text-muted);">
                    ℹ️ Les champs <span class="required-star">*</span> sont obligatoires
                </span>
                <button type="submit" class="btn btn-primary">
                    💾 Enregistrer les modifications
                </button>
            </div>
        </form>
    </div>

    {# ══════════════════════════════════════
       CARD 2 — Change Password
    ══════════════════════════════════════ #}
    <div class="form-panel" style="margin-bottom:24px;">

        <div class="form-panel-header">
            <span class="form-panel-icon">🔐</span>
            <div>
                <div class="form-panel-title">Sécurité</div>
                <div class="form-panel-sub">Changez votre mot de passe</div>
            </div>
        </div>
        <hr class="panel-divider">

        <form method="post" action="{{ path('admin_profile') }}"
              data-turbo="false" id="passwordForm" novalidate>
            <input type="hidden" name="action" value="change_password">

            <div class="form-group" style="margin-bottom:16px; max-width:420px;">
                <label class="form-label">
                    Mot de passe actuel <span class="required-star">*</span>
                </label>
                <input type="password"
                       name="current_password"
                       id="currentPwd"
                       class="form-control"
                       placeholder="••••••••"
                       required>
                <span class="field-error" id="err-current"></span>
            </div>

            <div class="form-row" style="margin-bottom:24px;">
                <div class="form-group">
                    <label class="form-label">
                        Nouveau mot de passe <span class="required-star">*</span>
                    </label>
                    <input type="password"
                           name="new_password"
                           id="newPwd"
                           class="form-control"
                           placeholder="••••••••"
                           required
                           minlength="8">
                    <span class="field-error" id="err-new"></span>
                    <span class="form-hint">8 caractères min, une majuscule, un chiffre</span>
                </div>
                <div class="form-group">
                    <label class="form-label">
                        Confirmer <span class="required-star">*</span>
                    </label>
                    <input type="password"
                           name="confirm_password"
                           id="confirmPwd"
                           class="form-control"
                           placeholder="••••••••"
                           required>
                    <span class="field-error" id="err-confirm"></span>
                </div>
            </div>

            <div class="form-actions">
                <div class="info-box" style="flex:1;">
                    <span class="info-box-icon">🔒</span>
                    <div>
                        <div class="info-box-title">Conseils de sécurité</div>
                        <div class="info-box-text">
                            Utilisez un mot de passe unique avec majuscules,
                            chiffres et caractères spéciaux.
                        </div>
                    </div>
                </div>
                <button type="submit" class="btn btn-outline" style="margin-left:16px;">
                    🔑 Changer le mot de passe
                </button>
            </div>
        </form>
    </div>

    {# ══════════════════════════════════════
       CARD 3 — Logout
    ══════════════════════════════════════ #}
    <div class="form-panel" style="border-color:#fca5a5;">
        <div class="form-panel-header">
            <span class="form-panel-icon">⚠️</span>
            <div>
                <div class="form-panel-title" style="color:var(--danger);">
                    Zone de déconnexion
                </div>
                <div class="form-panel-sub">Vous serez redirigé vers la page de connexion</div>
            </div>
        </div>
        <hr class="panel-divider">
        <div style="display:flex; align-items:center; gap:16px; padding-top:8px;">
            <form method="post" action="{{ path('app_logout') }}" data-turbo="false">
                <button type="submit" class="btn btn-danger-outline">
                    🚪 Se déconnecter
                </button>
            </form>
            <span style="font-size:13px; color:var(--text-muted);">
                Votre session sera terminée et vous devrez vous reconnecter.
            </span>
        </div>
    </div>

</div>

<style>
.field-error {
    font-size: 11px;
    color: #EF4444;
    padding-left: 4px;
    min-height: 16px;
    display: block;
}
</style>

<script>
// ── Avatar preview then auto-submit ──
function previewAndSubmit(input) {
    if (!input.files || !input.files[0]) return;

    const file = input.files[0];

    if (file.size > 5 * 1024 * 1024) {
        alert('Image trop volumineuse (max 5MB)');
        input.value = '';
        return;
    }

    const allowedTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
    if (!allowedTypes.includes(file.type)) {
        alert('Format invalide. Utilisez JPG, PNG, GIF ou WEBP.');
        input.value = '';
        return;
    }

    const reader = new FileReader();
    reader.onload = function(e) {
        const preview    = document.getElementById('avatarPreview');
        const defaultDiv = document.getElementById('avatarDefault');

        if (preview) {
            preview.src          = e.target.result;
            preview.style.display = 'block';
        }
        if (defaultDiv) {
            defaultDiv.style.display = 'none';
        }

        // Auto-submit the upload form
        input.closest('form').submit();
    };
    reader.readAsDataURL(file);
}

// ── Password validation ──
document.getElementById('passwordForm').addEventListener('submit', function(e) {
    let valid = true;

    const setError = (id, msg) => {
        const el = document.getElementById(id);
        if (el) { el.textContent = msg; if (msg) valid = false; }
    };

    const current = document.getElementById('currentPwd')?.value || '';
    const next    = document.getElementById('newPwd')?.value    || '';
    const confirm = document.getElementById('confirmPwd')?.value || '';

    setError('err-current', !current ? 'Champ requis.' : '');
    setError('err-new',
        !next               ? 'Champ requis.'           :
        next.length < 8     ? 'Au moins 8 caractères.'  :
        !/[A-Z]/.test(next) ? 'Une majuscule requise.'  :
        !/[0-9]/.test(next) ? 'Un chiffre requis.'      : ''
    );
    setError('err-confirm',
        next !== confirm ? 'Les mots de passe ne correspondent pas.' : ''
    );

    if (!valid) e.preventDefault();
});
</script>
{% endblock %}
{% extends 'base.html.twig' %}
{% block title %}Gestion des Utilisateurs — Admin{% endblock %}

{% block body %}

{# ── Flash messages ── #}
{% for message in app.flashes('success') %}
    <div class="flash flash-success">✅ {{ message }}</div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="flash flash-error">❌ {{ message }}</div>
{% endfor %}

{# ══════════════════════════════════════
   PAGE HEADER
══════════════════════════════════════ #}
<div class="page-header">
    <div>
        <div class="page-title">👥 Gestion des Utilisateurs</div>
        <div class="page-sub">Total: {{ stats.total }} utilisateur(s)</div>
    </div>
</div>

{# ══════════════════════════════════════
   STATISTICS CARDS
══════════════════════════════════════ #}
<div style="display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:24px;">

    <div class="card" style="padding:24px; text-align:center;">
        <div style="font-size:32px; margin-bottom:8px;">👨‍🎓</div>
        <div style="font-size:32px; font-weight:800; color:var(--primary);">{{ stats.etudiants }}</div>
        <div style="font-size:13px; color:var(--text-muted); font-weight:600;">Étudiants</div>
    </div>

    <div class="card" style="padding:24px; text-align:center;">
        <div style="font-size:32px; margin-bottom:8px;">👨‍💼</div>
        <div style="font-size:32px; font-weight:800; color:var(--primary);">{{ stats.prestataires }}</div>
        <div style="font-size:13px; color:var(--text-muted); font-weight:600;">Prestataires</div>
    </div>

    <div class="card" style="padding:24px; text-align:center;">
        <div style="font-size:32px; margin-bottom:8px;">✅</div>
        <div style="font-size:32px; font-weight:800; color:#16a34a;">{{ stats.active }}</div>
        <div style="font-size:13px; color:var(--text-muted); font-weight:600;">Actifs</div>
    </div>

    <div class="card" style="padding:24px; text-align:center;">
        <div style="font-size:32px; margin-bottom:8px;">⏸️</div>
        <div style="font-size:32px; font-weight:800; color:#d97706;">{{ stats.inactive }}</div>
        <div style="font-size:13px; color:var(--text-muted); font-weight:600;">Inactifs</div>
    </div>

</div>

{# ══════════════════════════════════════
   FILTERS BAR
══════════════════════════════════════ #}
<form method="get" action="{{ path('admin_dashboard') }}" data-turbo="false">
<div class="card" style="padding:20px; margin-bottom:20px; display:flex; align-items:center; gap:12px; flex-wrap:wrap;">

    <span style="font-size:14px; font-weight:600; color:var(--text-sub);">Filtrer par:</span>

    {# Type filter buttons #}
    {% for label, value in {'Tous': 'ALL', 'Étudiants': 'ETUDIANT', 'Prestataires': 'PRESTATAIRE'} %}
        <button type="submit"
                name="filter"
                value="{{ value }}"
                class="btn btn-sm {% if filter == value %}btn-primary{% else %}btn-ghost{% endif %}"
                {% if search %}onclick="this.form.querySelector('[name=q]').value='{{ search }}'"{% endif %}>
            {{ label }}
        </button>
    {% endfor %}

    <div style="flex:1;"></div>

    {# Search input #}
    <div class="search-bar-wrap" style="margin:0; width:300px;">
        <span class="search-bar-icon">🔍</span>
        <input type="text"
               name="q"
               value="{{ search }}"
               placeholder="Rechercher par nom ou email..."
               class="search-bar"
               style="padding:10px 16px 10px 38px;">
    </div>

    <button type="submit" name="filter" value="{{ filter }}" class="btn btn-ghost btn-sm">
        🔄 Actualiser
    </button>

</div>
</form>

{# ══════════════════════════════════════
   USERS TABLE
══════════════════════════════════════ #}
<div class="card" style="overflow:hidden;">
    <table style="width:100%; border-collapse:collapse;">

        {# Header #}
        <thead>
            <tr style="background:#f9fafb; border-bottom:2px solid var(--border);">
                <th style="padding:12px 16px; text-align:left; font-size:13px; font-weight:700; color:var(--text-sub);">Nom</th>
                <th style="padding:12px 16px; text-align:left; font-size:13px; font-weight:700; color:var(--text-sub);">Email</th>
                <th style="padding:12px 16px; text-align:left; font-size:13px; font-weight:700; color:var(--text-sub);">Type</th>
                <th style="padding:12px 16px; text-align:left; font-size:13px; font-weight:700; color:var(--text-sub);">Info</th>
                <th style="padding:12px 16px; text-align:left; font-size:13px; font-weight:700; color:var(--text-sub);">Téléphone</th>
                <th style="padding:12px 16px; text-align:left; font-size:13px; font-weight:700; color:var(--text-sub);">Statut</th>
                <th style="padding:12px 16px; text-align:center; font-size:13px; font-weight:700; color:var(--text-sub);">Actions</th>
            </tr>
        </thead>

        <tbody>
        {% if users is empty %}
            <tr>
                <td colspan="7" style="padding:60px; text-align:center; color:var(--text-muted);">
                    <div style="font-size:48px; margin-bottom:12px;">📭</div>
                    <div style="font-size:14px;">Aucun utilisateur trouvé</div>
                </td>
            </tr>
        {% else %}
            {% for user in users %}
            <tr style="border-bottom:1px solid #f3f4f6; transition:background 0.1s;"
                onmouseover="this.style.background='#f9fafb'"
                onmouseout="this.style.background='white'">

                {# Nom #}
                <td style="padding:12px 16px;">
                    <div style="display:flex; align-items:center; gap:10px;">
                        <div style="width:34px; height:34px; border-radius:50%; background:var(--primary-light);
                                    display:flex; align-items:center; justify-content:center;
                                    font-size:13px; font-weight:700; color:var(--primary);">
                            {{ user.name|slice(0,1)|upper }}
                        </div>
                        <span style="font-size:13px; font-weight:600; color:var(--text);">{{ user.name }}</span>
                    </div>
                </td>

                {# Email #}
                <td style="padding:12px 16px; font-size:13px; color:var(--text-muted);">
                    {{ user.email }}
                </td>

                {# Type badge #}
                <td style="padding:12px 16px;">
                    {% if user.userType == 'ETUDIANT' %}
                        <span class="badge" style="background:#dbeafe; color:#1e40af;">🎓 Étudiant</span>
                    {% elseif user.userType == 'PRESTATAIRE' %}
                        <span class="badge" style="background:#f3e8ff; color:#7c3aed;">💼 Prestataire</span>
                    {% endif %}
                </td>

                {# Info #}
                <td style="padding:12px 16px; font-size:13px; color:var(--text-muted);">
                    {% if user.userType == 'ETUDIANT' %}
                        {{ user.universite ?? '-' }}
                    {% elseif user.userType == 'PRESTATAIRE' %}
                        {{ user.specialization ?? '-' }}
                    {% endif %}
                </td>

                {# Phone #}
                <td style="padding:12px 16px; font-size:13px; color:var(--text-muted);">
                    {{ user.phone ?? '-' }}
                </td>

                {# Status badge #}
                <td style="padding:12px 16px;">
                    {% if user.status == 'ACTIVE' %}
                        <span class="badge badge-active">✅ Actif</span>
                    {% elseif user.status == 'INACTIVE' %}
                        <span class="badge badge-inactive">⏸ Inactif</span>
                    {% elseif user.status == 'BANNED' %}
                        <span class="badge badge-rejected">🚫 Banni</span>
                    {% else %}
                        <span class="badge badge-inactive">-</span>
                    {% endif %}
                </td>

                {# Actions #}
                <td style="padding:12px 16px;">
                    <div style="display:flex; gap:6px; justify-content:center;">

                        {# Activate #}
                        <form method="post" action="{{ path('admin_user_activate', {id: user.id}) }}" data-turbo="false">
                            <button type="submit"
                                    class="btn btn-sm"
                                    style="background:#f0fdf4; color:#15803d; border-color:#bbf7d0;"
                                    title="Activer"
                                    onclick="return confirm('Activer {{ user.name }} ?')">
                                ✅
                            </button>
                        </form>

                        {# Deactivate #}
                        <form method="post" action="{{ path('admin_user_deactivate', {id: user.id}) }}" data-turbo="false">
                            <button type="submit"
                                    class="btn btn-sm"
                                    style="background:#fffbeb; color:#d97706; border-color:#fde68a;"
                                    title="Désactiver"
                                    onclick="return confirm('Désactiver {{ user.name }} ?')">
                                ⏸️
                            </button>
                        </form>

                        {# Ban #}
                        <form method="post" action="{{ path('admin_user_ban', {id: user.id}) }}" data-turbo="false">
                            <button type="submit"
                                    class="btn btn-sm btn-danger-outline"
                                    title="Bannir"
                                    onclick="return confirm('⚠️ Bannir {{ user.name }} définitivement ?')">
                                🚫
                            </button>
                        </form>

                    </div>
                </td>

            </tr>
            {% endfor %}
        {% endif %}
        </tbody>

    </table>
</div>

{% endblock %}
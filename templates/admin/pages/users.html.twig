{% extends 'base.html.twig' %}
{% block title %}Gestion des Utilisateurs — Admin{% endblock %}

{% block body %}

{# ── Flash messages ── #}
{% for message in app.flashes('success') %}
    <div class="flash flash-success">✅ {{ message }}</div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="flash flash-error">❌ {{ message }}</div>
{% endfor %}

{# ══════════════════════════════════════
   PAGE HEADER
══════════════════════════════════════ #}
<div class="page-header">
    <div>
        <div class="page-title">👥 Gestion des Utilisateurs</div>
        <div class="page-sub">Total: {{ stats.total }} utilisateur(s)</div>
    </div>
</div>

{# ══════════════════════════════════════
   STATISTICS CARDS
══════════════════════════════════════ #}
<div style="display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:24px;">

    <div class="card" style="padding:24px; text-align:center;">
        <div style="font-size:32px; margin-bottom:8px;">👨‍🎓</div>
        <div style="font-size:32px; font-weight:800; color:var(--primary);">{{ stats.etudiants }}</div>
        <div style="font-size:13px; color:var(--text-muted); font-weight:600;">Étudiants</div>
    </div>

    <div class="card" style="padding:24px; text-align:center;">
        <div style="font-size:32px; margin-bottom:8px;">👨‍💼</div>
        <div style="font-size:32px; font-weight:800; color:var(--primary);">{{ stats.prestataires }}</div>
        <div style="font-size:13px; color:var(--text-muted); font-weight:600;">Prestataires</div>
    </div>

    <div class="card" style="padding:24px; text-align:center;">
        <div style="font-size:32px; margin-bottom:8px;">✅</div>
        <div style="font-size:32px; font-weight:800; color:#16a34a;">{{ stats.active }}</div>
        <div style="font-size:13px; color:var(--text-muted); font-weight:600;">Actifs</div>
    </div>

    <div class="card" style="padding:24px; text-align:center;">
        <div style="font-size:32px; margin-bottom:8px;">⏸️</div>
        <div style="font-size:32px; font-weight:800; color:#d97706;">{{ stats.inactive }}</div>
        <div style="font-size:13px; color:var(--text-muted); font-weight:600;">Inactifs</div>
    </div>

</div>

{# ══════════════════════════════════════
   CHARTS SECTION
══════════════════════════════════════ #}
<div style="display:grid; grid-template-columns:repeat(2,1fr); gap:24px; margin-bottom:24px;">
    
    {# Chart 1: Répartition par type #}
    <div class="card" style="padding:24px;">
        <h3 style="margin:0 0 16px 0; font-size:16px; font-weight:700; color:var(--text);">
            📊 Répartition par Type
        </h3>
        <div style="position:relative; height:300px;">
            <canvas id="typeChart"></canvas>
        </div>
    </div>

    {# Chart 2: Statut des utilisateurs #}
    <div class="card" style="padding:24px;">
        <h3 style="margin:0 0 16px 0; font-size:16px; font-weight:700; color:var(--text);">
            📈 Statut des Utilisateurs
        </h3>
        <div style="position:relative; height:300px;">
            <canvas id="statusChart"></canvas>
        </div>
    </div>

</div>

{# ══════════════════════════════════════
   FILTERS BAR — Avec HTMX pour la recherche
══════════════════════════════════════ #}
<form method="get" 
      action="{{ path('admin_dashboard') }}" 
      id="filterForm"
      data-turbo="false"
      {# HTMX: pour les boutons de filtre (submit classique) #}
      hx-target="#usersTableBody"
      hx-swap="outerHTML">
      
<div class="card" style="padding:20px; margin-bottom:20px; display:flex; align-items:center; gap:12px; flex-wrap:wrap;">

    <span style="font-size:14px; font-weight:600; color:var(--text-sub);">Filtrer par:</span>

    {# Type filter buttons — Submit classique (recharge les stats aussi) #}
    {% for label, value in {'Tous': 'ALL', 'Étudiants': 'ETUDIANT', 'Prestataires': 'PRESTATAIRE'} %}
        <button type="submit"
                name="filter"
                value="{{ value }}"
                class="btn btn-sm {% if filter == value %}btn-primary{% else %}btn-ghost{% endif %}">
            {{ label }}
        </button>
    {% endfor %}

    <div style="flex:1;"></div>

    {# Search input — RECHERCHE INSTANTANÉE #}
<div class="search-bar-wrap" style="margin:0; width:300px; position:relative;">
    <span class="search-bar-icon">🔍</span>
    {# 🔍 Search input — RECHERCHE VRAIMENT INSTANTANÉE #}
        <input type="text"
    name="q"
    value="{{ search }}"
    placeholder="Rechercher par nom ou email..."
    class="search-bar"
    
    hx-get="{{ path('admin_dashboard') }}"
    
    hx-trigger="keyup "
    hx-target="#usersTableBody"
    hx-swap="outerHTML"
    hx-include="[name='filter'],[name='page']"
    hx-push-url="true">
    
</div>

    {# Bouton Actualiser — Submit classique #}
    <button type="submit" name="filter" value="{{ filter }}" class="btn btn-ghost btn-sm">
        🔄 Actualiser
    </button>

    {# Hidden input for page #}
    <input type="hidden" name="page" value="1">

</div>
</form>

{# ══════════════════════════════════════
   USERS TABLE — tbody avec ID pour HTMX
══════════════════════════════════════ #}
<div class="card" style="overflow:hidden;">
    <table style="width:100%; border-collapse:collapse;">

        {# Header — TOUJOURS visible (pas dans le fragment) #}
        <thead>
            <tr style="background:#f9fafb; border-bottom:2px solid var(--border);">
                <th style="padding:12px 16px; text-align:left; font-size:13px; font-weight:700; color:var(--text-sub);">Nom</th>
                <th style="padding:12px 16px; text-align:left; font-size:13px; font-weight:700; color:var(--text-sub);">Email</th>
                <th style="padding:12px 16px; text-align:left; font-size:13px; font-weight:700; color:var(--text-sub);">Type</th>
                <th style="padding:12px 16px; text-align:left; font-size:13px; font-weight:700; color:var(--text-sub);">Info</th>
                <th style="padding:12px 16px; text-align:left; font-size:13px; font-weight:700; color:var(--text-sub);">Téléphone</th>
                <th style="padding:12px 16px; text-align:left; font-size:13px; font-weight:700; color:var(--text-sub);">Statut</th>
                <th style="padding:12px 16px; text-align:center; font-size:13px; font-weight:700; color:var(--text-sub);">Actions</th>
            </tr>
        </thead>

        {# 🔥 BODY AVEC ID — Cible de HTMX #}
        <tbody id="usersTableBody">
        {% if pagination.items is empty %}
            <tr>
                <td colspan="7" style="padding:60px; text-align:center; color:var(--text-muted);">
                    <div style="font-size:48px; margin-bottom:12px;">📭</div>
                    <div style="font-size:14px;">Aucun utilisateur trouvé</div>
                </td>
            </tr>
        {% else %}
            {% for user in pagination.items %}
            <tr style="border-bottom:1px solid #f3f4f6; transition:background 0.1s;"
                onmouseover="this.style.background='#f9fafb'"
                onmouseout="this.style.background='white'">

                {# Nom #}
                <td style="padding:12px 16px;">
                    <div style="display:flex; align-items:center; gap:10px;">
                        <div style="width:34px; height:34px; border-radius:50%; background:var(--primary-light);
                                    display:flex; align-items:center; justify-content:center;
                                    font-size:13px; font-weight:700; color:var(--primary);">
                            {{ user.name|slice(0,1)|upper }}
                        </div>
                        <span style="font-size:13px; font-weight:600; color:var(--text);">{{ user.name }}</span>
                    </div>
                </td>

                {# Email #}
                <td style="padding:12px 16px; font-size:13px; color:var(--text-muted);">
                    {{ user.email }}
                </td>

                {# Type badge #}
                <td style="padding:12px 16px;">
                    {% if user.userType == 'ETUDIANT' %}
                        <span class="badge" style="background:#dbeafe; color:#1e40af;">🎓 Étudiant</span>
                    {% elseif user.userType == 'PRESTATAIRE' %}
                        <span class="badge" style="background:#f3e8ff; color:#7c3aed;">💼 Prestataire</span>
                    {% endif %}
                </td>

                {# Info #}
                <td style="padding:12px 16px; font-size:13px; color:var(--text-muted);">
                    {% if user.userType == 'ETUDIANT' %}
                        {{ user.universite ?? '-' }}
                    {% elseif user.userType == 'PRESTATAIRE' %}
                        {{ user.specialization ?? '-' }}
                    {% endif %}
                </td>

                {# Phone #}
                <td style="padding:12px 16px; font-size:13px; color:var(--text-muted);">
                    {{ user.phone ?? '-' }}
                </td>

                {# Status badge #}
                <td style="padding:12px 16px;">
                    {% if user.status == 'ACTIVE' %}
                        <span class="badge badge-active">✅ Actif</span>
                    {% elseif user.status == 'INACTIVE' %}
                        <span class="badge badge-inactive">⏸ Inactif</span>
                    {% elseif user.status == 'BANNED' %}
                        <span class="badge badge-rejected">🚫 Banni</span>
                    {% else %}
                        <span class="badge badge-inactive">-</span>
                    {% endif %}
                </td>

                {# Actions #}
                <td style="padding:12px 16px;">
                    <div style="display:flex; gap:6px; justify-content:center;">

                        {# Activate #}
                        <form method="post" action="{{ path('admin_user_activate', {id: user.id}) }}" data-turbo="false">
                            <button type="submit"
                                    class="btn btn-sm"
                                    style="background:#f0fdf4; color:#15803d; border-color:#bbf7d0;"
                                    title="Activer"
                                    onclick="return confirm('Activer {{ user.name }} ?')">
                                ✅
                            </button>
                        </form>

                        {# Deactivate #}
                        <form method="post" action="{{ path('admin_user_deactivate', {id: user.id}) }}" data-turbo="false">
                            <button type="submit"
                                    class="btn btn-sm"
                                    style="background:#fffbeb; color:#d97706; border-color:#fde68a;"
                                    title="Désactiver"
                                    onclick="return confirm('Désactiver {{ user.name }} ?')">
                                ⏸️
                            </button>
                        </form>

                        {# Ban #}
                        <form method="post" action="{{ path('admin_user_ban', {id: user.id}) }}" data-turbo="false">
                            <button type="submit"
                                    class="btn btn-sm btn-danger-outline"
                                    title="Bannir"
                                    onclick="return confirm('⚠️ Bannir {{ user.name }} définitivement ?')">
                                🚫
                            </button>
                        </form>

                    </div>
                </td>

            </tr>
            {% endfor %}
        {% endif %}
        </tbody>

    </table>
</div>

{# ══════════════════════════════════════
   PAGINATION CONTROLS — Mise à jour avec HTMX
══════════════════════════════════════ #}
{% if pagination.pageCount > 1 %}
<div style="margin-top:20px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; padding:16px; background:#f9fafb; border-radius:8px; border:1px solid var(--border);"
     id="paginationControls">

    {# Info : "Page X sur Y" #}
    <div style="font-size:13px; color:var(--text-muted);">
        Page <strong>{{ pagination.currentPageNumber }}</strong> sur {{ pagination.pageCount }}
        &nbsp;•&nbsp;
        {{ pagination.totalItemCount }} utilisateur(s)
        &nbsp;•&nbsp;
        {{ pagination.itemNumberPerPage }} par page
    </div>

    {# Liens de pagination — Avec HTMX #}
    <div style="display:flex; gap:4px; flex-wrap:wrap; align-items:center;">
        
        {# Previous #}
        {% if pagination.currentPageNumber > 1 %}
            <a href="{{ path('admin_dashboard', {
                page: pagination.currentPageNumber - 1,
                filter: filter,
                q: search
            }) }}" 
               class="btn btn-sm btn-ghost"
               style="text-decoration:none;"
               hx-get="{{ path('admin_dashboard', {
                   page: pagination.currentPageNumber - 1,
                   filter: filter,
                   q: search
               }) }}"
               hx-target="#usersTableBody"
               hx-swap="outerHTML"
               hx-push-url="true">← Précédent</a>
        {% else %}
            <span class="btn btn-sm btn-ghost" style="opacity:0.5; cursor:not-allowed; text-decoration:none;">← Précédent</span>
        {% endif %}

        {# Pages numérotées #}
        {% for page in 1..pagination.pageCount %}
            {% if page == pagination.currentPageNumber %}
                <span class="btn btn-sm btn-primary" style="pointer-events:none; font-weight:700;">{{ page }}</span>
            {% elseif page == 1 or page == pagination.pageCount or (page >= pagination.currentPageNumber - 1 and page <= pagination.currentPageNumber + 1) %}
                <a href="{{ path('admin_dashboard', {
                    page: page,
                    filter: filter,
                    q: search
                }) }}" 
                   class="btn btn-sm btn-ghost"
                   style="text-decoration:none;"
                   hx-get="{{ path('admin_dashboard', {
                       page: page,
                       filter: filter,
                       q: search
                   }) }}"
                   hx-target="#usersTableBody"
                   hx-swap="outerHTML"
                   hx-push-url="true">{{ page }}</a>
            {% elseif page == pagination.currentPageNumber - 2 or page == pagination.currentPageNumber + 2 %}
                <span style="padding:6px 8px; color:var(--text-muted); font-weight:600;">...</span>
            {% endif %}
        {% endfor %}

        {# Next #}
        {% if pagination.currentPageNumber < pagination.pageCount %}
            <a href="{{ path('admin_dashboard', {
                page: pagination.currentPageNumber + 1,
                filter: filter,
                q: search
            }) }}" 
               class="btn btn-sm btn-ghost"
               style="text-decoration:none;"
               hx-get="{{ path('admin_dashboard', {
                   page: pagination.currentPageNumber + 1,
                   filter: filter,
                   q: search
               }) }}"
               hx-target="#usersTableBody"
               hx-swap="outerHTML"
               hx-push-url="true">Suivant →</a>
        {% else %}
            <span class="btn btn-sm btn-ghost" style="opacity:0.5; cursor:not-allowed; text-decoration:none;">Suivant →</span>
        {% endif %}

    </div>
</div>
{% endif %}

<style>
/* Pagination buttons styles */
.btn-sm {
    padding: 6px 12px;
    font-size: 13px;
    border-radius: 6px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    border: 1px solid var(--border, #e5e7eb);
    transition: all 0.15s ease;
}
.btn-sm.btn-ghost {
    background: transparent;
    color: var(--text, #1f2937);
}
.btn-sm.btn-ghost:hover {
    background: #f3f4f6;
    border-color: var(--primary, #4F46E5);
    color: var(--primary, #4F46E5);
}
.btn-sm.btn-primary {
    background: var(--primary, #4F46E5);
    border-color: var(--primary, #4F46E5);
    color: white;
}
.badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    border-radius: 9999px;
    font-size: 11px;
    font-weight: 600;
}
.badge-active { background: #dcfce7; color: #166534; }
.badge-inactive { background: #fef3c7; color: #92400e; }
.badge-rejected { background: #fee2e2; color: #991b1b; }
#resultsCount td {
    transition: all 150ms ease;
}
.htmx-request #resultsCount td {
    opacity: 0.6;
}
</style>

{# Chart.js CDN #}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<script>
// ── Chart 1: Répartition par Type (Doughnut) ──
const typeCtx = document.getElementById('typeChart').getContext('2d');
new Chart(typeCtx, {
    type: 'doughnut',
    data: {
        labels: ['Étudiants', 'Prestataires'],
        datasets: [{
            data: [{{ stats.etudiants }}, {{ stats.prestataires }}],
            backgroundColor: [
                '#3b82f6',
                '#a855f7'
            ],
            borderWidth: 0,
            hoverOffset: 4
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: {
                position: 'bottom',
                labels: { padding: 15, font: { size: 12 } }
            },
            tooltip: {
                callbacks: {
                    label: function(context) {
                        const label = context.label || '';
                        const value = context.parsed || 0;
                        const total = context.dataset.data.reduce((a, b) => a + b, 0);
                        const percentage = total > 0 ? Math.round((value / total) * 100) : 0;
                        return `${label}: ${value} (${percentage}%)`;
                    }
                }
            }
        },
        cutout: '60%'
    }
});

// ── Chart 2: Statut des Utilisateurs (Bar) ──
const statusCtx = document.getElementById('statusChart').getContext('2d');
new Chart(statusCtx, {
    type: 'bar',
    data: {
        labels: ['Actifs', 'Inactifs'],
        datasets: [{
            label: 'Nombre d\'utilisateurs',
            data: [{{ stats.active }}, {{ stats.inactive }}],
            backgroundColor: [
                'rgba(34, 197, 94, 0.8)',
                'rgba(234, 179, 8, 0.8)'
            ],
            borderColor: [
                'rgb(34, 197, 94)',
                'rgb(234, 179, 8)'
            ],
            borderWidth: 2,
            borderRadius: 8,
            barThickness: 60
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: { display: false },
            tooltip: {
                callbacks: {
                    label: function(context) {
                        const value = context.parsed.y;
                        const total = {{ stats.active }} + {{ stats.inactive }};
                        const percentage = total > 0 ? Math.round((value / total) * 100) : 0;
                        return `${value} utilisateurs (${percentage}%)`;
                    }
                }
            }
        },
        scales: {
            y: {
                beginAtZero: true,
                ticks: { stepSize: 1, precision: 0 },
                grid: { color: 'rgba(0, 0, 0, 0.05)' }
            },
            x: { grid: { display: false } }
        }
    }
});

// ── HTMX Event: Reset spinner après swap ──
document.body.addEventListener('htmx:afterSwap', function(evt) {
    if (evt.detail.target.id === 'usersTableBody') {
        const spinner = document.getElementById('searchSpinner');
        if (spinner) spinner.classList.remove('htmx-request');
    }
});
</script>

{% endblock %}
{% extends 'base.html.twig' %}

{% block title %}Gestion des avis - CampusLink Admin{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/AdminReviewsManagement.css') }}">
{% endblock %}

{% block body %}
<div class="page-content">

    <!-- FLASH MESSAGES -->
    {% for msg in app.flashes('success') %}
        <div class="flash flash-success">✅ {{ msg }}</div>
    {% endfor %}
    {% for msg in app.flashes('error') %}
        <div class="flash flash-error">❌ {{ msg }}</div>
    {% endfor %}

    <!-- HEADER -->
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
        <h1 class="page-title">Gestion des avis</h1>
        <div class="export-group">
            <a href="{{ path('admin_reviews_export', {format: 'csv'}) }}" class="btn btn-secondary btn-sm">📥 Export CSV</a>
            <a href="{{ path('admin_reviews_export', {format: 'pdf'}) }}" class="btn btn-secondary btn-sm" target="_blank">📄 Export PDF</a>
        </div>
    </div>

    <!-- STATISTIQUES -->
    <div class="stats-grid">
        <div class="stats-card">
            <div class="stats-label">Total des avis</div>
            <div style="display:flex; align-items:center; gap:8px;">
                <span class="stats-value">{{ stats.total }}</span>
                <span class="stats-icon">📝</span>
            </div>
        </div>
        <div class="stats-card">
            <div class="stats-label">Avis positifs</div>
            <div style="display:flex; align-items:center; gap:8px;">
                <span class="stats-value-green">{{ stats.positive }}</span>
                <span class="stats-icon">👍</span>
            </div>
        </div>
        <div class="stats-card">
            <div class="stats-label">Avis négatifs</div>
            <div style="display:flex; align-items:center; gap:8px;">
                <span class="stats-value-red">{{ stats.negative }}</span>
                <span class="stats-icon">👎</span>
            </div>
        </div>
        <div class="stats-card">
            <div class="stats-label">Signalés</div>
            <div style="display:flex; align-items:center; gap:8px;">
                <span class="stats-value-amber">{{ stats.reported }}</span>
                <span class="stats-icon">⚠️</span>
            </div>
        </div>
    </div>

    <!-- FILTRES -->
    <form method="get" action="{{ path('admin_reviews_index') }}" class="filter-section" id="filterForm">
        <div class="filter-group">
            <label class="filter-label">Prestataire</label>
            <select name="prestataire" id="filterPrestataire" class="filter-select">
                <option value="">Tous les prestataires</option>
                {% for p in prestataires %}
                    <option value="{{ p }}" {{ filterPrestataire == p ? 'selected' : '' }}>{{ p }}</option>
                {% endfor %}
            </select>
        </div>

        <div class="filter-group">
            <label class="filter-label">Note</label>
            <select name="rating" id="filterRating" class="filter-select">
                <option value="">Toutes les notes</option>
                <option value="positive"      {{ filterRating == 'positive'      ? 'selected' : '' }}>Positives (+1 à +5)</option>
                <option value="negative"      {{ filterRating == 'negative'      ? 'selected' : '' }}>Négatives (-5 à -1)</option>
                <option value="very_positive" {{ filterRating == 'very_positive' ? 'selected' : '' }}>Très positives (+4 et +5)</option>
                <option value="very_negative" {{ filterRating == 'very_negative' ? 'selected' : '' }}>Très négatives (-5 et -4)</option>
                <option value="neutral"       {{ filterRating == 'neutral'       ? 'selected' : '' }}>Neutres (0)</option>
                <option value="reported"      {{ filterRating == 'reported'      ? 'selected' : '' }}>🚩 Signalés uniquement</option>
            </select>
        </div>

        <div class="filter-group" style="flex:1;">
            <label class="filter-label">Recherche</label>
            <input
                type="text"
                name="search"
                id="filterSearch"
                class="filter-input"
                placeholder="Commentaire, service, étudiant, prestataire..."
                value="{{ filterSearch }}"
            >
        </div>

        <div class="filter-group">
            <label class="filter-label">&nbsp;</label>
            <div style="display:flex; gap:8px;">
                <button type="button" id="btnFilter" class="btn btn-primary btn-sm">🔍 Filtrer</button>
                <button type="button" id="btnReset" class="btn btn-secondary btn-sm">🔄 Reset</button>
            </div>
        </div>
    </form>

    <!-- RÉSULTAT FILTRE -->
    <div id="filterResult" style="margin-bottom:16px; font-size:14px; color:var(--text-muted); display:none;"></div>

    <!-- LOADING -->
    <div id="loadingSpinner" style="display:none; text-align:center; padding:40px; font-size:18px;">
        ⏳ Chargement...
    </div>

    <!-- LISTE DES AVIS -->
    <div class="reviews-list" id="reviewsList">
        {% if reviews is empty %}
            <div class="empty-state">
                📝 Aucun avis trouvé.<br>
                {% if filterPrestataire or filterRating or filterSearch %}
                    <small><a href="{{ path('admin_reviews_index') }}" style="color:var(--primary);">Voir tous les avis</a></small>
                {% else %}
                    <small>Les avis apparaîtront ici.</small>
                {% endif %}
            </div>
        {% else %}
            {% for review in reviews %}
                {% set rating    = review.rating %}
                {% set absRating = (rating < 0 ? -rating : rating) %}
                {% if absRating > 5 %}
                    {% set absRating = 5 %}
                {% endif %}
                {% set colorClass = rating < 0 ? 'stars-negative' : (rating > 0 ? 'stars-positive' : 'stars-neutral') %}

                <div class="review-card {{ review.isReported ? 'is-reported' : '' }}">

                    <!-- HEADER -->
                    <div class="card-header">
                        <div class="card-info-grid">
                            <div class="info-student">👤 Étudiant : {{ review.student.name ?? 'Inconnu' }}</div>
                            <div class="info-service">📚 Service : {{ review.reservation.service.title ?? 'Inconnu' }}</div>
                            <div class="info-prestataire">🎓 Prestataire : {{ review.prestataire.name ?? 'Inconnu' }}</div>
                        </div>
                        <div class="card-date">{{ 'now'|date('d/m/Y') }}</div>
                    </div>

                    <!-- STARS -->
                    <div class="stars-display">
                        <span class="stars {{ colorClass }}">
                            {% for i in 1..5 %}{% if i <= absRating %}★{% else %}☆{% endif %}{% endfor %}
                        </span>
                        <span class="stars-badge {{ colorClass }}">
                            {{ rating > 0 ? '(+' ~ rating ~ ')' : '(' ~ rating ~ ')' }}
                        </span>
                    </div>

                    <!-- BANNER SIGNALEMENT -->
                    {% if review.isReported %}
                        <div class="report-banner">
                            <span class="report-banner-icon">⚠️</span>
                            <div>
                                <div class="report-banner-title">Signalé par le prestataire</div>
                                <div class="report-banner-text">Raison : {{ review.reportReason ?? 'Non précisée' }}</div>
                                {% if review.reportedAt %}
                                    <div class="report-banner-text">
                                        Signalé le : {{ review.reportedAt|date('d/m/Y à H:i') }}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    {% endif %}

                    <!-- COMMENTAIRE -->
                    <p class="review-comment">{{ review.comment }}</p>

                    <!-- FOOTER -->
                    <div class="card-footer">
                        <span class="badge
                            {% if rating == 5 %}badge-excellent
                            {% elseif rating == 4 %}badge-good
                            {% elseif rating == 3 %}badge-average
                            {% elseif rating < 0 %}badge-negative
                            {% else %}badge-average{% endif %}">
                            {% if rating == 5 %}⭐ Excellent
                            {% elseif rating == 4 %}👍 Très bien
                            {% elseif rating == 3 %}😊 Bien
                            {% elseif rating < 0 %}👎 Avis négatif
                            {% else %}⚠️ À améliorer{% endif %}
                        </span>

                        <div style="display:flex; gap:8px; flex-wrap:wrap;">
                            <button onclick="openDetailsModal({{ review.id }})" class="btn btn-secondary btn-sm">👁 Voir détails</button>

                            {% if review.isReported %}
                                <form method="post" action="{{ path('admin_reviews_unreport', {id: review.id}) }}" style="display:inline;">
                                    <button type="submit" class="btn btn-success btn-sm">✓ Marquer traité</button>
                                </form>
                            {% endif %}

                            <form method="post" action="{{ path('admin_reviews_delete', {id: review.id}) }}" style="display:inline;"
                                  onsubmit="return confirm('Supprimer cet avis ?\n\nÉtudiant : {{ review.student.name ?? '' }}\nPrestataire : {{ review.prestataire.name ?? '' }}\n\n⚠️ Action irréversible !')">
                                <button type="submit" class="btn btn-danger btn-sm">🗑 Supprimer</button>
                            </form>
                        </div>
                    </div>

                </div>
            {% endfor %}
        {% endif %}
    </div>
</div>

<!-- MODAL DÉTAILS -->
<div id="detailsModal" class="modal-overlay">
    <div class="form-card modal-box">
        <h2>👁 Détails de l'avis</h2>

        <div class="detail-row">
            <span class="detail-label">👤 Étudiant</span>
            <span class="detail-value" id="d-student"></span>
        </div>
        <div class="detail-row">
            <span class="detail-label">🎓 Prestataire</span>
            <span class="detail-value" id="d-prestataire"></span>
        </div>
        <div class="detail-row">
            <span class="detail-label">📚 Service</span>
            <span class="detail-value" id="d-service"></span>
        </div>
        <div class="detail-row">
            <span class="detail-label">⭐ Note</span>
            <span class="detail-value" id="d-rating"></span>
        </div>
        <div class="detail-row" style="flex-direction:column; gap:4px;">
            <span class="detail-label">💬 Commentaire</span>
            <span class="detail-value" id="d-comment" style="white-space:pre-wrap; background:#f9fafb; padding:10px; border-radius:8px; margin-top:4px;"></span>
        </div>

        <div id="d-report-section" style="display:none; margin-top:16px;">
            <div style="background:#fef3c7; border:1px solid #fcd34d; border-radius:8px; padding:14px;">
                <div style="font-weight:700; color:#92400e; margin-bottom:6px;">🚩 Signalement</div>
                <div class="detail-row">
                    <span class="detail-label">Raison</span>
                    <span class="detail-value" id="d-reason"></span>
                </div>
                <div class="detail-row" id="d-date-row">
                    <span class="detail-label">Date</span>
                    <span class="detail-value" id="d-date"></span>
                </div>
            </div>
        </div>

        <div style="margin-top:20px;">
            <button onclick="document.getElementById('detailsModal').classList.remove('open')" class="btn btn-secondary">Fermer</button>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
const apiSearchUrl = "{{ path('admin_reviews_api_search') }}";
const unreportUrl  = "{{ path('admin_reviews_unreport', {id: '__ID__'}) }}";
const deleteUrl    = "{{ path('admin_reviews_delete', {id: '__ID__'}) }}";

// ===================== AJAX SEARCH & FILTER =====================
async function loadReviews() {
    const prestataire = document.getElementById('filterPrestataire').value;
    const rating      = document.getElementById('filterRating').value;
    const search      = document.getElementById('filterSearch').value;

    const params = new URLSearchParams();
    if (prestataire) params.append('prestataire', prestataire);
    if (rating) params.append('rating', rating);
    if (search) params.append('search', search);

    const loadingSpinner = document.getElementById('loadingSpinner');
    const reviewsList    = document.getElementById('reviewsList');
    const filterResult   = document.getElementById('filterResult');

    loadingSpinner.style.display = 'block';
    reviewsList.innerHTML = '';

    try {
        const response = await fetch(`${apiSearchUrl}?${params.toString()}`);
        const data = await response.json();

        loadingSpinner.style.display = 'none';

        if (prestataire || rating || search) {
            filterResult.style.display = 'block';
            filterResult.innerHTML = `${data.count} avis trouvé${data.count > 1 ? 's' : ''}${search ? ' pour "<strong>' + search + '</strong>"' : ''}`;
        } else {
            filterResult.style.display = 'none';
        }

        if (data.reviews.length === 0) {
            reviewsList.innerHTML = `
                <div class="empty-state">
                    📝 Aucun avis trouvé.<br>
                    ${prestataire || rating || search ? '<small><a href="#" onclick="resetFilters(); return false;" style="color:var(--primary);">Voir tous les avis</a></small>' : '<small>Les avis apparaîtront ici.</small>'}
                </div>
            `;
        } else {
            reviewsList.innerHTML = data.reviews.map(review => renderReviewCard(review)).join('');
        }
    } catch (error) {
        loadingSpinner.style.display = 'none';
        reviewsList.innerHTML = '<div class="empty-state">❌ Erreur lors du chargement des avis.</div>';
        console.error('Erreur:', error);
    }
}

function renderReviewCard(review) {
    const colorClass = review.rating < 0 ? 'stars-negative' : (review.rating > 0 ? 'stars-positive' : 'stars-neutral');
    const stars = '★'.repeat(review.absRating) + '☆'.repeat(5 - review.absRating);
    const sign = review.rating > 0 ? '+' : '';
    
    let badgeClass = 'badge-average';
    let badgeText = '⚠️ À améliorer';
    if (review.rating === 5) { badgeClass = 'badge-excellent'; badgeText = '⭐ Excellent'; }
    else if (review.rating === 4) { badgeClass = 'badge-good'; badgeText = '👍 Très bien'; }
    else if (review.rating === 3) { badgeClass = 'badge-average'; badgeText = '😊 Bien'; }
    else if (review.rating < 0) { badgeClass = 'badge-negative'; badgeText = '👎 Avis négatif'; }

    const reportBanner = review.isReported ? `
        <div class="report-banner">
            <span class="report-banner-icon">⚠️</span>
            <div>
                <div class="report-banner-title">Signalé par le prestataire</div>
                <div class="report-banner-text">Raison : ${review.reportReason || 'Non précisée'}</div>
                ${review.reportedAt ? `<div class="report-banner-text">Signalé le : ${review.reportedAt}</div>` : ''}
            </div>
        </div>
    ` : '';

    const unreportBtn = review.isReported ? `
        <form method="post" action="${unreportUrl.replace('__ID__', review.id)}" style="display:inline;">
            <button type="submit" class="btn btn-success btn-sm">✓ Marquer traité</button>
        </form>
    ` : '';

    return `
        <div class="review-card ${review.isReported ? 'is-reported' : ''}">
            <div class="card-header">
                <div class="card-info-grid">
                    <div class="info-student">👤 Étudiant : ${review.student}</div>
                    <div class="info-service">📚 Service : ${review.service}</div>
                    <div class="info-prestataire">🎓 Prestataire : ${review.prestataire}</div>
                </div>
                <div class="card-date">${new Date().toLocaleDateString('fr-FR')}</div>
            </div>
            <div class="stars-display">
                <span class="stars ${colorClass}">${stars}</span>
                <span class="stars-badge ${colorClass}">(${sign}${review.rating})</span>
            </div>
            ${reportBanner}
            <p class="review-comment">${review.comment}</p>
            <div class="card-footer">
                <span class="badge ${badgeClass}">${badgeText}</span>
                <div style="display:flex; gap:8px; flex-wrap:wrap;">
                    <button onclick="openDetailsModal(${review.id})" class="btn btn-secondary btn-sm">👁 Voir détails</button>
                    ${unreportBtn}
                    <form method="post" action="${deleteUrl.replace('__ID__', review.id)}" style="display:inline;"
                          onsubmit="return confirm('Supprimer cet avis ?\\n\\nÉtudiant : ${review.student}\\nPrestataire : ${review.prestataire}\\n\\n⚠️ Action irréversible !')">
                        <button type="submit" class="btn btn-danger btn-sm">🗑 Supprimer</button>
                    </form>
                </div>
            </div>
        </div>
    `;
}

function resetFilters() {
    document.getElementById('filterPrestataire').value = '';
    document.getElementById('filterRating').value = '';
    document.getElementById('filterSearch').value = '';
    loadReviews();
}

// ===================== EVENT LISTENERS =====================
document.getElementById('btnFilter').addEventListener('click', loadReviews);
document.getElementById('btnReset').addEventListener('click', resetFilters);

document.getElementById('filterSearch').addEventListener('input', debounce(loadReviews, 500));
document.getElementById('filterPrestataire').addEventListener('change', loadReviews);
document.getElementById('filterRating').addEventListener('change', loadReviews);

function debounce(func, wait) {
    let timeout;
    return function(...args) {
        clearTimeout(timeout);
        timeout = setTimeout(() => func.apply(this, args), wait);
    };
}

// ===================== DETAILS MODAL =====================
async function openDetailsModal(reviewId) {
    try {
        const response = await fetch(`{{ path('admin_reviews_api_details', {id: '__ID__'}) }}`.replace('__ID__', reviewId));
        
        if (!response.ok) {
            alert('Erreur lors du chargement des détails');
            return;
        }

        const data = await response.json();

        document.getElementById('d-student').textContent     = data.student;
        document.getElementById('d-prestataire').textContent = data.prestataire;
        document.getElementById('d-service').textContent     = data.service;
        document.getElementById('d-comment').textContent     = data.comment;

        const sign = data.rating > 0 ? '+' : '';
        document.getElementById('d-rating').textContent = sign + data.rating;

        const reportSection = document.getElementById('d-report-section');
        if (data.isReported) {
            reportSection.style.display = 'block';
            document.getElementById('d-reason').textContent = data.reportReason || 'Non précisée';
            if (data.reportedAt) {
                document.getElementById('d-date').textContent   = data.reportedAt;
                document.getElementById('d-date-row').style.display = 'flex';
            } else {
                document.getElementById('d-date-row').style.display = 'none';
            }
        } else {
            reportSection.style.display = 'none';
        }

        document.getElementById('detailsModal').classList.add('open');
    } catch (error) {
        console.error('Erreur:', error);
        alert('Erreur lors du chargement des détails');
    }
}

document.getElementById('detailsModal').addEventListener('click', function (e) {
    if (e.target === this) this.classList.remove('open');
});

// ===================== INITIAL LOAD =====================
loadReviews();
</script>
{% endblock %}
{# NO extends — this is a bare fragment for HTMX #}
<tbody id="usersTableBody">
{% if pagination.items is empty %}
    <tr>
        <td colspan="7" style="padding:60px; text-align:center; color:var(--text-muted);">
            <div style="font-size:48px; margin-bottom:12px;">📭</div>
            <div style="font-size:14px;">Aucun utilisateur trouvé</div>
        </td>
    </tr>
{% else %}
    {% for user in pagination.items %}
    <tr style="border-bottom:1px solid #f3f4f6; transition:background 0.1s;"
        onmouseover="this.style.background='#f9fafb'"
        onmouseout="this.style.background='white'">

        <td style="padding:12px 16px;">
            <div style="display:flex; align-items:center; gap:10px;">
                <div style="width:34px; height:34px; border-radius:50%; background:var(--primary-light);
                            display:flex; align-items:center; justify-content:center;
                            font-size:13px; font-weight:700; color:var(--primary);">
                    {{ user.name|slice(0,1)|upper }}
                </div>
                <span style="font-size:13px; font-weight:600; color:var(--text);">{{ user.name }}</span>
            </div>
        </td>

        <td style="padding:12px 16px; font-size:13px; color:var(--text-muted);">{{ user.email }}</td>

        <td style="padding:12px 16px;">
            {% if user.userType == 'ETUDIANT' %}
                <span class="badge" style="background:#dbeafe; color:#1e40af;">🎓 Étudiant</span>
            {% elseif user.userType == 'PRESTATAIRE' %}
                <span class="badge" style="background:#f3e8ff; color:#7c3aed;">💼 Prestataire</span>
            {% endif %}
        </td>

        <td style="padding:12px 16px; font-size:13px; color:var(--text-muted);">
            {% if user.userType == 'ETUDIANT' %}{{ user.universite ?? '-' }}
            {% elseif user.userType == 'PRESTATAIRE' %}{{ user.specialization ?? '-' }}
            {% endif %}
        </td>

        <td style="padding:12px 16px; font-size:13px; color:var(--text-muted);">{{ user.phone ?? '-' }}</td>

        <td style="padding:12px 16px;">
            {% if user.status == 'ACTIVE' %}
                <span class="badge badge-active">✅ Actif</span>
            {% elseif user.status == 'INACTIVE' %}
                <span class="badge badge-inactive">⏸ Inactif</span>
            {% elseif user.status == 'BANNED' %}
                <span class="badge badge-rejected">🚫 Banni</span>
            {% else %}
                <span class="badge badge-inactive">-</span>
            {% endif %}
        </td>

        <td style="padding:12px 16px;">
            <div style="display:flex; gap:6px; justify-content:center;">
                <form method="post" action="{{ path('admin_user_activate', {id: user.id}) }}" data-turbo="false">
                    <button type="submit" class="btn btn-sm"
                            style="background:#f0fdf4; color:#15803d; border-color:#bbf7d0;"
                            onclick="return confirm('Activer {{ user.name }} ?')">✅</button>
                </form>
                <form method="post" action="{{ path('admin_user_deactivate', {id: user.id}) }}" data-turbo="false">
                    <button type="submit" class="btn btn-sm"
                            style="background:#fffbeb; color:#d97706; border-color:#fde68a;"
                            onclick="return confirm('Désactiver {{ user.name }} ?')">⏸️</button>
                </form>
                <form method="post" action="{{ path('admin_user_ban', {id: user.id}) }}" data-turbo="false">
                    <button type="submit" class="btn btn-sm btn-danger-outline"
                            onclick="return confirm('⚠️ Bannir {{ user.name }} définitivement ?')">🚫</button>
                </form>
            </div>
        </td>
    </tr>
    {% endfor %}
{% endif %}
</tbody>
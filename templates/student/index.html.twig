{% extends 'base.html.twig' %}
{% block title %}Rechercher des services — CampusLink{% endblock %}
{% block body %}

<div class="page-header">
    <div>
        <div class="page-title">Rechercher des services</div>
    </div>
</div>

<form method="get" action="{{ path('student_index') }}" class="filters-bar">
    <input type="text" name="q" value="{{ app.request.query.get('q') }}"
           placeholder="Mots-clés..."
           class="filter-input" style="min-width:220px;flex:1;">
    <input type="number" name="priceMin" step="0.01" min="0" placeholder="Prix min"
           value="{{ app.request.query.get('priceMin') }}"
           class="filter-input" style="max-width:120px;">
    <input type="number" name="priceMax" step="0.01" min="0" placeholder="Prix max"
           value="{{ app.request.query.get('priceMax') }}"
           class="filter-input" style="max-width:120px;">
    <button type="submit" class="btn btn-primary btn-sm">Filtrer</button>
    <a href="{{ path('student_index') }}" class="btn btn-ghost btn-sm">Réinitialiser</a>
</form>

{% if services|length == 0 %}
<div class="empty-state" style="text-align:center;">
    <div style="font-size:48px;margin-bottom:12px;">🔍</div>
    <div>Aucun service ne correspond à votre recherche.</div>
</div>
{% else %}
<div class="cards-grid">
    {% for service in services %}
    {% set imageSrc = null %}
    {% if service.image %}
        {% set imageSrc = service.image starts with 'http' ? service.image : asset(service.image) %}
    {% endif %}
    {% set st = service.status %}
    {% set badgeClass = st == 'CONFIRMEE' ? 'badge-active' : (st == 'EN_ATTENTE' ? 'badge-pending' : (st == 'REFUSEE' ? 'badge-rejected' : 'badge-inactive')) %}
    {% set badgeLabel = st == 'CONFIRMEE' ? 'Confirmé' : (st == 'EN_ATTENTE' ? 'En attente' : (st == 'REFUSEE' ? 'Refusé' : 'Terminé')) %}
    <div class="card" style="display:flex;flex-direction:column;overflow:hidden;">
        <div style="height:180px;background:#f3f4f6;display:flex;align-items:center;justify-content:center;overflow:hidden;">
            {% if imageSrc %}
                <img src="{{ imageSrc }}" alt="{{ service.title }}" style="width:100%;height:100%;object-fit:cover;">
            {% else %}
                <div style="display:flex;flex-direction:column;align-items:center;gap:8px;color:#9ca3af;">
                    <div style="font-size:34px;">🖼️</div>
                    <div style="font-size:12px;">Aucune image</div>
                </div>
            {% endif %}
        </div>
        <div style="display:flex;flex-direction:column;padding:18px;gap:10px;flex:1;">
            <div style="display:flex;justify-content:space-between;gap:10px;align-items:flex-start;">
                <div style="font-size:16px;font-weight:800;line-height:1.3;">{{ service.title }}</div>
                {% if app.user and service.user == app.user and app.user.userType == 'PRESTATAIRE' %}
                <span class="badge {{ badgeClass }}">{{ badgeLabel }}</span>
                {% endif %}
            </div>
            <div style="font-size:13px;color:#6b7280;">
                {{ service.category ? (service.category.nom ?? service.category.name) : 'Non catégorisé' }}
            </div>
            {% if service.user %}
            <div style="font-size:13px;color:#6b7280;">👤 {{ service.user.name }}</div>
            {% endif %}
            {% if service.description %}
            <div style="font-size:14px;color:#374151;line-height:1.5;flex:1;">
                {{ service.description|length > 150 ? service.description|slice(0,150) ~ '…' : service.description }}
            </div>
            {% endif %}
            <div style="display:flex;gap:16px;font-size:13px;color:#9ca3af;align-items:center;">
                <span>⏱ 1h</span>
                <span>📅 {{ service.reservations is defined ? service.reservations|length : 0 }} réservations</span>
            </div>
            <div style="font-size:22px;font-weight:800;color:var(--primary);">{{ service.price|number_format(2, ',', ' ') }} DT</div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;">
                <a href="{{ path('service_show', {id: service.id}) }}" class="btn btn-ghost" style="flex:1;justify-content:center;min-width:120px;">Voir détail</a>
                <button type="button" class="btn btn-primary" style="flex:1;justify-content:center;min-width:120px;">📅 Réserver</button>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}

{% endblock %}
